generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PortfolioUser {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  password            String
  name                String?
  emailVerified       Boolean   @default(false)
  verificationCode    String?
  verificationExpires DateTime?
  passkeyFailedAttempts Int     @default(0)
  createdAt           DateTime  @default(now())
  passkeys            Passkey[]
}

model Passkey {
  id           String        @id @default(uuid())
  credentialID String        @unique
  publicKey    String        // Stored as base64-url
  counter      BigInt
  transports   String?       // Comma-separated list of transport options
  userId       Int
  user         PortfolioUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
