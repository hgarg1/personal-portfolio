generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cells {
  run_id       String
  cell_id      String
  parent_id    String?
  generation   Int
  birth_step   Int
  death_step   Int?
  status       String
  alive        Boolean
  x            Float
  y            Float
  z            Float
  atp          Float
  biomass      Float
  updated_step Int
  payload      Json
  runs         runs    @relation(fields: [run_id], references: [run_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([run_id, cell_id])
  @@index([cell_id], map: "idx_cells_cell_id")
  @@index([run_id, generation], map: "idx_cells_run_generation")
  @@index([run_id, parent_id], map: "idx_cells_run_parent")
  @@index([run_id, status], map: "idx_cells_run_status")
}

model email_verification_tokens {
  token_hash String   @id
  user_id    String
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model events {
  event_id   BigInt  @id @default(autoincrement())
  run_id     String
  step       Int
  time       Float
  event_type String
  cell_id    String?
  message    String
  values     Json
  runs       runs    @relation(fields: [run_id], references: [run_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([run_id, cell_id, step], map: "idx_events_run_cell_step", where: raw("(cell_id IS NOT NULL)"))
  @@index([run_id, step, event_id], map: "idx_events_run_step")
  @@index([run_id, event_type, step], map: "idx_events_run_type_step")
  @@index([values], map: "idx_events_values_gin", type: Gin)
}

model oauth_accounts {
  provider            String
  provider_account_id String
  user_id             String
  email               String?
  access_token        Json?
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  updated_at          DateTime @default(now()) @db.Timestamptz(6)
  users               users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([provider, provider_account_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model password_policy {
  policy_id         String   @id
  min_length        Int
  require_uppercase Boolean  @default(true)
  require_lowercase Boolean  @default(true)
  require_digit     Boolean  @default(true)
  require_special   Boolean  @default(true)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)
}

model password_reset_tokens {
  token_hash String   @id
  user_id    String
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model runs {
  run_id             String         @id
  scenario_name      String
  scenario_hash      String
  engine_version     String
  seed               Int
  status             String
  started_at         DateTime       @db.Timestamptz(6)
  completed_at       DateTime?      @db.Timestamptz(6)
  max_steps          Int
  final_step         Int?
  termination_reason String?
  scenario           Json
  current_state      Json
  rng_state          Json
  created_at         DateTime       @default(now()) @db.Timestamptz(6)
  updated_at         DateTime       @default(now()) @db.Timestamptz(6)
  owner_user_id      String?
  cells              cells[]
  events             events[]
  users              users?         @relation(fields: [owner_user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  step_metrics       step_metrics[]

  @@index([owner_user_id, started_at(sort: Desc)], map: "idx_runs_owner_started_at")
  @@index([scenario_name, started_at(sort: Desc)], map: "idx_runs_scenario_started_at")
  @@index([status, started_at(sort: Desc)], map: "idx_runs_status_started_at")
}

model sessions {
  session_id String   @id
  user_id    String
  token_hash String   @unique
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, expires_at(sort: Desc)], map: "idx_sessions_user_expires")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model step_metrics {
  run_id               String
  step                 Int
  time                 Float
  population_count     Int
  alive_count          Int
  dead_count           Int
  divided_count        Int
  division_count_total Int
  total_atp            Float
  total_biomass        Float
  toxicity             Float
  payload              Json
  environment_food     Float  @default(0)
  environment_oxygen   Float  @default(0)
  runs                 runs   @relation(fields: [run_id], references: [run_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([run_id, step])
  @@index([run_id, step], map: "idx_step_metrics_run_step")
  @@index([step], map: "idx_step_metrics_step")
}

model users {
  user_id                   String                      @id
  email                     String                      @unique
  password_hash             String
  name                      String?
  email_verified_at         DateTime?                   @db.Timestamptz(6)
  created_at                DateTime                    @default(now()) @db.Timestamptz(6)
  updated_at                DateTime                    @default(now()) @db.Timestamptz(6)
  email_verification_tokens email_verification_tokens[]
  oauth_accounts            oauth_accounts[]
  password_reset_tokens     password_reset_tokens[]
  runs                      runs[]
  sessions                  sessions[]
}

model PortfolioUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
