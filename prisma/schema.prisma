generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PortfolioUser {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  password            String
  name                String?
  emailVerified       Boolean   @default(false)
  verificationCode    String?
  verificationExpires DateTime?
  createdAt           DateTime  @default(now())
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
