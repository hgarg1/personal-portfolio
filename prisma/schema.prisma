generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

model PortfolioUser {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  password            String
  name                String?
  emailVerified       Boolean   @default(false)
  verificationCode    String?
  verificationExpires DateTime?
  passkeyFailedAttempts Int     @default(0)
  role                Role      @default(VIEWER)
  createdAt           DateTime  @default(now())
  passkeys            Passkey[]
  cmsPages            CMSPage[]
  cmsAssets           CMSAsset[]
}

model Passkey {
  id           String        @id @default(uuid())
  credentialID String        @unique
  publicKey    String        // Stored as base64-url
  counter      BigInt
  transports   String?       // Comma-separated list of transport options
  userId       Int
  user         PortfolioUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model CMSPage {
  id           Int           @id @default(autoincrement())
  slug         String        @unique
  title        String
  description  String?
  layout       String        @default("standard") // "standard", "blank"
  themeColor   String        @default("#6366f1")
  gradient     String        @default("linear-gradient(135deg, #9d5cff 0%, #00d4ff 100%)")
  htmlContent  String        @db.Text
  cssContent   String        @db.Text
  jsContent    String        @db.Text
  status       String        @default("DRAFT") // "DRAFT", "STAGED", "PUBLISHED"
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  authorId     Int?
  author       PortfolioUser? @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model CMSAsset {
  id           Int            @id @default(autoincrement())
  filename     String         @unique
  originalName String
  mimeType     String
  size         Int
  url          String
  createdAt    DateTime       @default(now())
  uploadedById Int?
  uploadedBy   PortfolioUser? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
}

