<%- include('./partials/head') %>

<section class="page-hero section">
  <div class="container text-center">
    <div class="hero-badge">Say Hello</div>
    <h1 class="page-title">Get in <span class="gradient-text">Touch</span></h1>
    <p class="page-subtitle">Have a question or want to collaborate? We would love to hear from you.</p>
  </div>
</section>

<section class="contact-section section">
  <div class="container">
    <div class="contact-wrapper">

      <% if (success) { %>
      <div class="alert alert-success">&#10003; &nbsp;<%= success %></div>
      <% } %>

      <% if (error) { %>
      <div class="alert alert-error">&#9888; &nbsp;<%= error %></div>
      <% } %>

      <form class="contact-form" action="/contact" method="POST" id="contactForm" novalidate>
        <div class="form-group">
          <label for="name" class="form-label">Full Name</label>
          <input
            type="text"
            id="name"
            name="name"
            class="form-input"
            placeholder="Jane Doe"
            required
          />
        </div>

        <div class="form-group">
          <label for="email" class="form-label">Email Address</label>
          <input
            type="email"
            id="email"
            name="email"
            class="form-input"
            placeholder="jane@example.com"
            required
          />
        </div>

        <div class="form-group">
          <label for="message" class="form-label">Message</label>
          <textarea
            id="message"
            name="message"
            class="form-input form-textarea"
            placeholder="Tell us what is on your mind..."
            rows="5"
            required
          ></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-full" id="submitBtn">
          Send Message &#10022;
        </button>
      </form>

    </div>
  </div>
</section>

<%- include('./partials/foot') %>
