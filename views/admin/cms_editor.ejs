  };

  // 1. Initialize Widget Palette Sidebar
  function initWidgetPalette() {
    const palette = document.getElementById('widget-palette');
    if (!palette) return;
    palette.innerHTML = '';
    
    Object.keys(WIDGET_REGISTRY).forEach(type => {
      const widget = WIDGET_REGISTRY[type];
      const card = document.createElement('div');
      card.className = 'widget-palette-item';
      card.setAttribute('draggable', 'true');
      card.setAttribute('data-type', type);
      card.innerHTML = `
        <i data-lucide="${widget.icon}"></i>
        <div style="display: flex; flex-direction: column;">
          <span style="font-size: 0.85rem; font-weight: 600;">${widget.name}</span>
        </div>
      `;
      
      // Drag Events
      card.addEventListener('dragstart', (e) => {
        e.dataTransfer.setData('text/plain', type);
        e.dataTransfer.effectAllowed = 'move';
      });

      palette.appendChild(card);
    });

    if (window.lucide) window.lucide.createIcons({ attrs: { class: 'lucide-icon' } });
  }

  // 2. Initialize SortableJS for Center Canvas
  function initCanvasSortable() {
    const canvas = document.getElementById('builder-canvas');
    if (!canvas) return;

    sortableInstance = Sortable.create(canvas, {
      animation: 180,
      handle: '.canvas-block-overlay',
      ghostClass: 'sortable-ghost',
      chosenClass: 'sortable-chosen',
      dragClass: 'sortable-drag',
      onEnd: function() {
        // Re-order our state array
        const newOrderIds = Array.from(canvas.children).map(child => child.id);
        const reordered = [];
        newOrderIds.forEach(id => {
          const block = canvasBlocks.find(b => b.id === id);
          if (block) reordered.push(block);
        });
        canvasBlocks = reordered;
        serializeCanvasToHTML();
      }
    });

    // Also support dropping new items onto canvas via dragover/drop
    const wrapper = document.getElementById('builder-canvas-wrapper');
    wrapper.addEventListener('dragover', (e) => {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
    });

    wrapper.addEventListener('drop', (e) => {
      e.preventDefault();
      const type = e.dataTransfer.getData('text/plain');
      if (type && WIDGET_REGISTRY[type]) {
        // Find drop index based on mouse Y position
        const children = Array.from(canvas.children);
        let dropIndex = children.length;
        
        for (let i = 0; i < children.length; i++) {
          const rect = children[i].getBoundingClientRect();
          const midY = rect.top + rect.height / 2;
          if (e.clientY < midY) {
            dropIndex = i;
            break;
          }
        }
        
        addBlockToCanvas(type, dropIndex);
      }
    });
  }

  // 3. Render Canvas Blocks
  function renderCanvas() {
    const canvas = document.getElementById('builder-canvas');
    if (!canvas) return;
    canvas.innerHTML = '';

    if (canvasBlocks.length === 0) {
      const placeholder = document.createElement('div');
      placeholder.className = 'builder-placeholder';
      placeholder.innerHTML = `
        <i data-lucide="layout"></i>
        <h3 style="font-family: var(--font-head); font-size: 1.1rem; font-weight: 700; margin: 0; color: var(--text);">Canvas is Empty</h3>
        <p style="font-size: 0.85rem; margin: 0; line-height: 1.5;">Drag blocks from the palette on the left or double click one to assemble your portfolio layout.</p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; margin-top: 0.5rem;">
          ${Object.keys(WIDGET_REGISTRY).map(type => `
            <button onclick="addBlockToCanvas('${type}')" class="canvas-btn" style="padding: 4px 10px;">+ ${WIDGET_REGISTRY[type].name}</button>
          `).join('')}
        </div>
      `;
      canvas.appendChild(placeholder);
      if (window.lucide) window.lucide.createIcons();
      return;
    }

    canvasBlocks.forEach(block => {
      const widget = WIDGET_REGISTRY[block.type];
      if (!widget) return;

      const card = document.createElement('div');
      card.className = `canvas-block ${block.id === activeBlockId ? 'active-block' : ''}`;
      card.id = block.id;
      
      // Select block on click
      card.addEventListener('click', (e) => {
        // Prevent if clicking active buttons
        if (e.target.closest('.canvas-btn')) return;
        selectBlock(block.id);
      });

      // Open config drawer on double click
      card.addEventListener('dblclick', (e) => {
        if (e.target.closest('.canvas-btn')) return;
        openConfigDrawer(block.id);
      });

      card.innerHTML = `
        <!-- Overlay Header -->
        <div class="canvas-block-overlay">
          <span class="canvas-block-title" style="cursor: grab;">
            <i data-lucide="${widget.icon}"></i> ${widget.name}
          </span>
          <div class="canvas-block-controls">
            <button class="canvas-btn" onclick="openConfigDrawer('${block.id}')"><i data-lucide="sliders"></i> Edit</button>
            <button class="canvas-btn" onclick="duplicateBlock('${block.id}')"><i data-lucide="copy"></i> Duplicate</button>
            <button class="canvas-btn delete-btn" onclick="deleteBlock('${block.id}')"><i data-lucide="trash-2"></i> Delete</button>
          </div>
        </div>
        <!-- Visual Render -->
        <div class="canvas-block-content-wrapper" id="preview-${block.id}">
          ${widget.render(block.config)}
        </div>
      `;

      canvas.appendChild(card);
    });

    if (window.lucide) window.lucide.createIcons();
  }

  // 4. State Modification Handlers
  function selectBlock(id) {
    activeBlockId = id;
    document.querySelectorAll('.canvas-block').forEach(el => {
      el.classList.toggle('active-block', el.id === id);
    });
  }

  window.addBlockToCanvas = function(type, index = null) {
    if (!WIDGET_REGISTRY[type]) return;
    
    // Build default config
    const config = {};
    const schema = WIDGET_REGISTRY[type].config;
    Object.keys(schema).forEach(key => {
      // Deep clone default values to prevent shared reference bugs
      config[key] = JSON.parse(JSON.stringify(schema[key].default));
    });

    const newBlock = {
      id: 'block-' + Math.random().toString(36).substr(2, 9),
      type: type,
      config: config
    };

    if (index !== null) {
      canvasBlocks.splice(index, 0, newBlock);
    } else {
      canvasBlocks.push(newBlock);
    }

    activeBlockId = newBlock.id;
    renderCanvas();
    serializeCanvasToHTML();
    
    // Auto open editing panel
    openConfigDrawer(newBlock.id);
  };

  window.duplicateBlock = function(id) {
    const block = canvasBlocks.find(b => b.id === id);
    if (!block) return;

    const index = canvasBlocks.indexOf(block);
    const newBlock = {
      id: 'block-' + Math.random().toString(36).substr(2, 9),
      type: block.type,
      config: JSON.parse(JSON.stringify(block.config))
    };

    canvasBlocks.splice(index + 1, 0, newBlock);
    activeBlockId = newBlock.id;
    renderCanvas();
    serializeCanvasToHTML();
    openConfigDrawer(newBlock.id);
  };

  window.deleteBlock = function(id) {
    canvasBlocks = canvasBlocks.filter(b => b.id !== id);
    if (activeBlockId === id) {
      activeBlockId = null;
      closeConfigDrawer();
    }
    renderCanvas();
    serializeCanvasToHTML();
  };

  // 5. Configurator Drawer UI Builder
  window.openConfigDrawer = function(id) {
    const block = canvasBlocks.find(b => b.id === id);
    if (!block) return;

    selectBlock(id);
    const drawer = document.getElementById('builder-drawer');
    const formContainer = document.getElementById('config-form-container');
    if (!drawer || !formContainer) return;

    formContainer.innerHTML = '';
    const widget = WIDGET_REGISTRY[block.type];

    Object.keys(widget.config).forEach(key => {
      const field = widget.config[key];
      const val = block.config[key];

      const wrapper = document.createElement('div');
      wrapper.className = 'drawer-field';

      const label = document.createElement('label');
      label.textContent = field.label;
      wrapper.appendChild(label);

      let inputHtml = '';
      if (field.type === 'text') {
        inputHtml = `<input type="text" class="drawer-input" value="${(val || '').toString().replace(/"/g, '&quot;')}" oninput="updateBlockConfig('${id}', '${key}', this.value)" />`;
      } else if (field.type === 'textarea') {
        inputHtml = `<textarea class="drawer-input" rows="5" oninput="updateBlockConfig('${id}', '${key}', this.value)">${val || ''}</textarea>`;
      } else if (field.type === 'select') {
        inputHtml = `<select class="drawer-input" onchange="updateBlockConfig('${id}', '${key}', this.value)">
          ${field.options.map(opt => `<option value="${opt}" ${opt === val ? 'selected' : ''}>${opt}</option>`).join('')}
        </select>`;
      } else if (field.type === 'color') {
        inputHtml = `<div style="display: flex; gap: 0.5rem;"><input type="text" data-coloris class="drawer-input color-picker-input" style="flex: 1;" value="${val || '#ffffff'}" onchange="updateBlockConfig('${id}', '${key}', this.value)" /></div>`;
      } else if (field.type === 'array') {
        // Array items editor
        const arr = val || [];
        inputHtml = `<div class="array-editor-container">
          <div style="display: flex; flex-direction: column; gap: 0.75rem;" id="array-items-${id}-${key}">
            ${arr.map((item, idx) => `
              <div class="array-item-card">
                <div class="array-item-header">
                  <span style="font-weight: 600;">Card #${idx + 1}</span>
                  <button class="canvas-btn delete-btn" onclick="removeArrayItem('${id}', '${key}', ${idx})">✕ Remove</button>
                </div>
                ${Object.keys(field.default[0]).map(subKey => {
                  const subVal = item[subKey] || '';
                  return `
                    <div class="drawer-field">
                      <label style="font-size: 0.72rem; color: var(--text-muted);">${subKey.charAt(0).toUpperCase() + subKey.slice(1)}</label>
                      <input type="text" class="drawer-input" value="${subVal.toString().replace(/"/g, '&quot;')}" oninput="updateArraySubfield('${id}', '${key}', ${idx}, '${subKey}', this.value)" />
                    </div>
                  `;
                }).join('')}
              </div>
            `).join('')}
          </div>
          <button class="canvas-btn" style="margin-top: 0.5rem; width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.25rem; font-weight: 600;" onclick="addArrayItem('${id}', '${key}')"><i data-lucide="plus" style="width: 14px; height: 14px;"></i> Add New Item</button>
        </div>`;
      }

      const inputContainer = document.createElement('div');
      inputContainer.innerHTML = inputHtml;
      wrapper.appendChild(inputContainer.firstElementChild || inputContainer);
      formContainer.appendChild(wrapper);
    });

    drawer.style.display = 'flex';
    
    // Bind Coloris to new inputs
    if (window.Coloris) {
      window.Coloris({
        el: '[data-coloris]',
        theme: 'dark',
        themeMode: 'dark',
        format: 'hex',
        clearButton: false
      });
    }

    if (window.lucide) window.lucide.createIcons();
  };

  window.closeConfigDrawer = function() {
    const drawer = document.getElementById('builder-drawer');
    if (drawer) drawer.style.display = 'none';
  };

  window.closeConfigDrawerOnBackdrop = function(e) {
    if (e.target.id === 'builder-drawer') {
      closeConfigDrawer();
    }
  };

  window.updateBlockConfig = function(id, key, value) {
    const block = canvasBlocks.find(b => b.id === id);
    if (!block) return;
    block.config[key] = value;
    
    // Live update preview in canvas immediately without fully re-rendering all blocks
    const previewEl = document.getElementById(`preview-${id}`);
    if (previewEl) {
      previewEl.innerHTML = WIDGET_REGISTRY[block.type].render(block.config);
    }
    
    serializeCanvasToHTML();
  };

  window.updateBlockPreview = function(id) {
    const block = canvasBlocks.find(b => b.id === id);
    if (!block) return;
    const previewEl = document.getElementById(`preview-${id}`);
    if (previewEl) {
      previewEl.innerHTML = WIDGET_REGISTRY[block.type].render(block.config);
    }
  };

  window.addArrayItem = function(blockId, key) {
    const block = canvasBlocks.find(b => b.id === blockId);
    if (!block) return;
    const schemaField = WIDGET_REGISTRY[block.type].config[key];
    const newItem = { ...schemaField.default[0] };
    Object.keys(newItem).forEach(k => newItem[k] = '');
    block.config[key].push(newItem);
    openConfigDrawer(blockId);
    updateBlockPreview(blockId);
    serializeCanvasToHTML();
  };

  window.removeArrayItem = function(blockId, key, idx) {
    const block = canvasBlocks.find(b => b.id === blockId);
    if (!block) return;
    block.config[key].splice(idx, 1);
    openConfigDrawer(blockId);
    updateBlockPreview(blockId);
    serializeCanvasToHTML();
  };

  window.updateArraySubfield = function(blockId, key, idx, subKey, value) {
    const block = canvasBlocks.find(b => b.id === blockId);
    if (!block) return;
    block.config[key][idx][subKey] = value;
    updateBlockPreview(blockId);
    serializeCanvasToHTML();
  };

  // 6. Bidirectional Sync Engines
  function serializeCanvasToHTML() {
    const htmlString = canvasBlocks.map(block => {
      const widget = WIDGET_REGISTRY[block.type];
      return widget ? widget.render(block.config).trim() : '';
    }).join('\n\n');

    if (htmlEditor) {
      // Set value in Monaco without triggering recursive loops
      const currentVal = htmlEditor.getValue();
      if (currentVal !== htmlString) {
        htmlEditor.setValue(htmlString);
      }
    }
  }

  function parseHTMLToCanvas(htmlContent) {
    canvasBlocks = [];
    const temp = document.createElement('div');
    temp.innerHTML = htmlContent;

    Array.from(temp.children).forEach(el => {
      if (el.nodeType !== Node.ELEMENT_NODE) return;

      const type = el.getAttribute('data-widget');
      let config = {};

      if (type && WIDGET_REGISTRY[type]) {
        const rawConfig = el.getAttribute('data-config');
        if (rawConfig) {
          try {
            config = JSON.parse(decodeURIComponent(rawConfig));
          } catch (e) {
            console.error('Failed to parse data-config URI payload', e);
          }
        }
        
        // Smart parse in case text elements were edited directly in Code Mode
        if (WIDGET_REGISTRY[type].parse) {
          try {
            config = WIDGET_REGISTRY[type].parse(el, config);
          } catch (e) {
            console.error(`Error executing parse block for ${type}`, e);
          }
        }

        canvasBlocks.push({
          id: 'block-' + Math.random().toString(36).substr(2, 9),
          type: type,
          config: config
        });
      } else {
        // Fallback to custom html block
        canvasBlocks.push({
          id: 'block-' + Math.random().toString(36).substr(2, 9),
          type: 'custom-html',
          config: {
            htmlCode: el.outerHTML
          }
        });
      }
    });

    renderCanvas();
  }

  // 7. Toggle Mode Wrapper
  function toggleEditorMode(mode) {
    const monacoContainer = document.getElementById('editor-html');
    const builderContainer = document.getElementById('builder-container');
    
    const codeTab = document.getElementById('editor-mode-code');
    const visualTab = document.getElementById('editor-mode-visual');

    if (mode === 'visual') {
      isVisualActive = true;
      codeTab.classList.remove('active-mode-btn');
      visualTab.classList.add('active-mode-btn');

      monacoContainer.style.display = 'none';
      builderContainer.style.display = 'block';

      try {
        const htmlContent = htmlEditor.getValue();
        parseHTMLToCanvas(htmlContent);
      } catch (err) {
        console.error('Error loading Block Builder:', err);
        showToastMsg('Error loading Visual Builder. Using Code Editor instead.', false);
        isVisualActive = false;
        codeTab.classList.add('active-mode-btn');
        visualTab.classList.remove('active-mode-btn');
        builderContainer.style.display = 'none';
        monacoContainer.style.display = 'block';
        if (htmlEditor) {
          setTimeout(() => htmlEditor.layout(), 50);
        }
      }
    } else {
      isVisualActive = false;
      codeTab.classList.add('active-mode-btn');
      visualTab.classList.remove('active-mode-btn');

      builderContainer.style.display = 'none';
      monacoContainer.style.display = 'block';
      closeConfigDrawer();
      
      serializeCanvasToHTML();

      if (htmlEditor) {
        setTimeout(() => htmlEditor.layout(), 50);
      }
    }
  }

  // Monaco Diff Editor Rendering
  function setDiffType(type) {
    document.querySelectorAll('#panel-diff .editor-mode-btn').forEach(btn => btn.classList.remove('active-mode-btn'));
    document.getElementById(`diff-btn-${type}`).classList.add('active-mode-btn');
    activeDiffType = type;
    updateDiffComparison();
  }

  async function updateDiffComparison() {
    if (!diffEditorInstance) return;

    const pageId = document.getElementById('page-id').value;
    const originalSelect = document.getElementById('diff-original-select');
    const modifiedSelect = document.getElementById('diff-modified-select');
    if (!originalSelect || !modifiedSelect) return;
    
    const originalHash = originalSelect.value;
    const modifiedHash = modifiedSelect.value;

    if (!originalHash || !modifiedHash) return;

    try {
      const fetchModifiedHash = (modifiedHash === 'unstaged') ? originalHash : modifiedHash;
      const response = await fetch(`/admin/cms/pages/${pageId}/diff?originalHash=${originalHash}&modifiedHash=${fetchModifiedHash}`);
      if (response.ok) {
        const data = await response.json();
        
        let origText = '', modText = '', language = 'html';

        if (activeDiffType === 'html') {
          origText = data.original.htmlContent;
          modText = (modifiedHash === 'unstaged') ? htmlEditor.getValue() : data.modified.htmlContent;
          language = 'html';
        } else if (activeDiffType === 'css') {
          origText = data.original.cssContent;
          modText = (modifiedHash === 'unstaged') ? cssEditor.getValue() : data.modified.cssContent;
          language = 'css';
        } else if (activeDiffType === 'js') {
          origText = data.original.jsContent;
          modText = (modifiedHash === 'unstaged') ? jsEditor.getValue() : data.modified.jsContent;
          language = 'javascript';
        }

        // Set Diff Editor Models
        const originalModel = monaco.editor.createModel(origText, language);
        const modifiedModel = monaco.editor.createModel(modText, language);

        const oldModel = diffEditorInstance.getModel();
        diffEditorInstance.setModel({
          original: originalModel,
          modified: modifiedModel
        });

        if (oldModel) {
          if (oldModel.original) oldModel.original.dispose();
          if (oldModel.modified) oldModel.modified.dispose();
        }
      }
    } catch (err) {
      console.error(err);
    }
  }

  function showToastMsg(message, isSuccess) {
    const toast = document.getElementById('toast');
    const toastIcon = document.getElementById('toast-icon');
    const toastMessage = document.getElementById('toast-message');

    toastIcon.textContent = isSuccess ? '✅' : '❌';
    toast.style.borderColor = isSuccess ? 'var(--cyan)' : '#ef4444';
    toastMessage.textContent = message;

    toast.style.display = 'flex';
    toast.style.opacity = '1';

    setTimeout(() => {
      toast.style.opacity = '0';
      setTimeout(() => {
        toast.style.display = 'none';
      }, 300);
    }, 3000);
  }
</script>

