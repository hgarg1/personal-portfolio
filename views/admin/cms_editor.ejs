        return `<div data-widget="custom-html" data-config="${encoded}" class="widget-rendered-section">
  ${config.htmlCode}
</div>`;
      },
      parse: function(el, currentConfig) {
        const config = { ...currentConfig };
        config.htmlCode = el.innerHTML.trim();
        return config;
      }
