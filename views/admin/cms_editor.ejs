<%- include('../partials/head') %>

<!-- Load CDN Helpers (Loaded before Monaco to prevent AMD define conflict) -->
<link href="https://cdn.jsdelivr.net/gh/mdbassit/Coloris@latest/dist/coloris.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js"></script>
<script src="https://cdn.jsdelivr.net/gh/mdbassit/Coloris@latest/dist/coloris.min.js"></script>

<!-- Load Monaco Editor via CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.43.0/min/vs/loader.min.js"></script>

<section class="section section-alt" style="padding-top: 80px; padding-bottom: 2rem; min-height: calc(100vh - 80px); display: flex; flex-direction: column;">
  <div class="container" style="max-width: 96% !important; width: 96% !important; padding-inline: 2rem; display: flex; flex-direction: column; flex: 1;">
    
    <!-- Editor Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
      <div style="display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;">
        <div>
          <h1 style="font-family: var(--font-head); font-size: 1.8rem; font-weight: 700; display: inline-flex; align-items: center; gap: 0.5rem; margin: 0;">
            <%= page ? 'Edit Page:' : 'Create New' %> <span class="gradient-text"><%= page ? page.title : 'Custom Page' %></span>
          </h1>
        </div>

        <% if (page) { %>
          <!-- Branch Switcher & Actions -->
          <div style="display: flex; align-items: center; gap: 0.5rem; background: rgba(255,255,255,0.03); border: 1px solid var(--border); border-radius: var(--r-md); padding: 0.35rem 0.75rem;">
            <span style="font-family: var(--font-mono); font-size: 0.78rem; color: var(--text-muted);">branch:</span>
            <select id="branch-select" onchange="switchBranch(this.value)" style="background: none; border: none; color: var(--text); font-family: var(--font-body); font-weight: 600; cursor: pointer; outline: none;">
              <% branches.forEach(function(b) { %>
                <option value="<%= b.name %>" <%= b.name === activeBranch ? 'selected' : '' %> style="background: var(--bg-card); color: var(--text);"><%= b.name %><%= b.isDefault ? ' (default)' : '' %></option>
              <% }); %>
            </select>
            <button onclick="openBranchModal()" style="font-size: 0.85rem; padding: 2px 6px; color: var(--cyan); border: 1px solid rgba(0, 212, 255, 0.2); border-radius: 4px; background: rgba(0, 212, 255, 0.05); font-weight: 600; cursor: pointer;" title="Create Branch">+ New</button>
            <button onclick="openMergeRequestModal()" style="font-size: 0.85rem; padding: 2px 6px; color: var(--purple); border: 1px solid rgba(157, 92, 255, 0.2); border-radius: 4px; background: rgba(157, 92, 255, 0.05); font-weight: 600; cursor: pointer;" title="Submit Merge Request">⇌ Merge</button>
          </div>
        <% } %>
      </div>
      
      <div style="display: flex; gap: 1rem; align-items: center;">
        <a href="/admin/cms" class="btn btn-ghost" style="padding: 0.5rem 1.2rem; font-size: 0.88rem;">
          <span>Cancel</span>
        </a>
        <button onclick="openCommitModal()" class="btn btn-primary" style="padding: 0.5rem 1.8rem; font-size: 0.88rem;">
          <span>Commit &amp; Save</span>
          <span>💾</span>
        </button>
      </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="toast-notification" style="display: none; position: fixed; bottom: 24px; right: 24px; background: rgba(10, 17, 31, 0.95); border: 1px solid var(--purple); border-radius: var(--r-md); padding: 1rem 1.5rem; color: var(--text); backdrop-filter: blur(10px); z-index: 100000; box-shadow: 0 10px 30px rgba(0,0,0,0.5); align-items: center; gap: 0.5rem;">
      <span id="toast-icon">ℹ️</span>
      <span id="toast-message"></span>
    </div>

    <!-- VCS Commit Message Modal -->
    <div id="commit-modal" class="vcs-modal-backdrop" style="display: none;">
      <div class="vcs-modal-container">
        <div class="vcs-modal-header">
          <h3>Commit Savepoint</h3>
          <button onclick="closeCommitModal()">✕</button>
        </div>
        <div class="vcs-modal-body">
          <label class="form-label">Commit Message</label>
          <input type="text" id="commit-message" placeholder="e.g. Updated content layout and styled background" class="form-input" style="font-family: var(--font-body);">
          <span style="font-size: 0.78rem; color: var(--text-muted); margin-top: 0.5rem; display: block;">Write a brief description of the modifications you made. This is added permanently to the revision tree.</span>
        </div>
        <div class="vcs-modal-footer">
          <button onclick="closeCommitModal()" class="btn btn-ghost" style="padding: 0.4rem 1.2rem; font-size: 0.85rem;">Cancel</button>
          <button onclick="savePage()" class="btn btn-primary" style="padding: 0.4rem 1.5rem; font-size: 0.85rem; box-shadow: none;">Commit &amp; Save</button>
        </div>
      </div>
    </div>

    <!-- VCS Create Branch Modal -->
    <div id="branch-modal" class="vcs-modal-backdrop" style="display: none;">
      <div class="vcs-modal-container">
        <div class="vcs-modal-header">
          <h3>Create New Branch</h3>
          <button onclick="closeBranchModal()">✕</button>
        </div>
        <div class="vcs-modal-body">
          <div style="margin-bottom: 1rem;">
            <label class="form-label">Branch Name</label>
            <input type="text" id="new-branch-name" placeholder="e.g. campaign-draft" class="form-input">
          </div>
          <div>
            <label class="form-label">Source Branch (Base HEAD)</label>
            <select id="source-branch-select" class="form-input">
              <% if (page) { %>
                <% branches.forEach(function(b) { %>
                  <option value="<%= b.id %>" <%= b.name === activeBranch ? 'selected' : '' %>><%= b.name %></option>
                <% }); %>
              <% } %>
            </select>
          </div>
        </div>
        <div class="vcs-modal-footer">
          <button onclick="closeBranchModal()" class="btn btn-ghost" style="padding: 0.4rem 1.2rem; font-size: 0.85rem;">Cancel</button>
          <button onclick="submitCreateBranch()" class="btn btn-primary" style="padding: 0.4rem 1.5rem; font-size: 0.85rem; box-shadow: none;">Create Branch</button>
        </div>
      </div>
    </div>

    <!-- VCS Merge Request Modal -->
    <div id="mr-modal" class="vcs-modal-backdrop" style="display: none;">
      <div class="vcs-modal-container">
        <div class="vcs-modal-header">
          <h3>Create Merge Request</h3>
          <button onclick="closeMergeRequestModal()">✕</button>
        </div>
        <div class="vcs-modal-body">
          <div style="margin-bottom: 1rem;">
            <label class="form-label">Merge Request Title</label>
            <input type="text" id="mr-title" placeholder="e.g. Merge marketing changes into production" class="form-input">
          </div>
          <div style="margin-bottom: 1rem;">
            <label class="form-label">Description / Summary</label>
            <textarea id="mr-description" placeholder="Describe the changes this merge applies." class="form-input" style="height: 60px; resize: none;"></textarea>
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div>
              <label class="form-label">Source Branch (Draft)</label>
              <select id="mr-source-select" class="form-input" disabled>
                <% if (page) { %>
                  <% branches.forEach(function(b) { %>
                    <option value="<%= b.id %>" <%= b.name === activeBranch ? 'selected' : '' %>><%= b.name %></option>
                  <% }); %>
                <% } %>
              </select>
            </div>
            <div>
              <label class="form-label">Target Branch (Dest)</label>
              <select id="mr-target-select" class="form-input">
                <% if (page) { %>
                  <% branches.forEach(function(b) { %>
                    <% if (b.name !== activeBranch) { %>
                      <option value="<%= b.id %>" <%= b.isDefault ? 'selected' : '' %>><%= b.name %></option>
                    <% } %>
                  <% }); %>
                <% } %>
              </select>
            </div>
          </div>
        </div>
        <div class="vcs-modal-footer">
          <button onclick="closeMergeRequestModal()" class="btn btn-ghost" style="padding: 0.4rem 1.2rem; font-size: 0.85rem;">Cancel</button>
          <button onclick="submitMergeRequest()" class="btn btn-primary" style="padding: 0.4rem 1.5rem; font-size: 0.85rem; box-shadow: none;">File Request</button>
        </div>
      </div>
    </div>

    <!-- Main Workspace Split Screen -->
    <div class="editor-workspace" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; flex: 1; min-height: 600px;">
      
      <!-- Left Panel: Configuration and Code Editors -->
      <div style="display: flex; flex-direction: column; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-lg); overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.3);">
        
        <!-- Tab Headers -->
        <div style="display: flex; background: rgba(8, 13, 26, 0.6); border-bottom: 1px solid var(--border);">
          <button onclick="switchWorkspaceTab('settings')" id="workspace-tab-settings" class="workspace-tab-btn active-w-tab">Settings</button>
          <button onclick="switchWorkspaceTab('html')" id="workspace-tab-html" class="workspace-tab-btn">HTML Body</button>
          <button onclick="switchWorkspaceTab('css')" id="workspace-tab-css" class="workspace-tab-btn">CSS Custom</button>
          <button onclick="switchWorkspaceTab('js')" id="workspace-tab-js" class="workspace-tab-btn">JS Scripts</button>
          <% if (page) { %>
            <button onclick="switchWorkspaceTab('diff')" id="workspace-tab-diff" class="workspace-tab-btn">VCS Diff Viewer</button>
          <% } %>
        </div>

        <div style="flex: 1; display: flex; flex-direction: column; position: relative;">
          
          <!-- SETTINGS TAB PANEL -->
          <div id="panel-settings" class="workspace-panel" style="padding: 2rem; overflow-y: auto; height: 100%; display: block;">
            
            <input type="hidden" id="page-id" value="<%= page ? page.id : '' %>">

            <!-- Title & Slug -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
              <div>
                <label class="form-label">Page Title</label>
                <input type="text" id="page-title" value="<%= page ? page.title : '' %>" placeholder="e.g. My Custom Portfolio" class="form-input" oninput="suggestSlug()">
              </div>
              <div>
                <label class="form-label">URL Slug</label>
                <input type="text" id="page-slug" value="<%= page ? page.slug : '' %>" placeholder="e.g. custom-portfolio" class="form-input" <%= page ? 'disabled' : '' %> title="<%= page ? 'URL Slug is global and locked while editing. Change slug redirects in settings panel.' : '' %>">
              </div>
            </div>

            <!-- Description -->
            <div style="margin-bottom: 1.5rem;">
              <label class="form-label">SEO Description (Meta Tag)</label>
              <textarea id="page-description" placeholder="Short summary describing the page content for SEO optimization." class="form-input" style="height: 60px; resize: none;"><%= page ? page.description : '' %></textarea>
            </div>

            <!-- Layout & Status -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
              <div>
                <label class="form-label">Layout Template</label>
                <select id="page-layout" class="form-input" onchange="triggerPreviewUpdate()">
                  <option value="standard" <%= page && page.layout === 'standard' ? 'selected' : '' %>>Standard (Navigation & Footer)</option>
                  <option value="blank" <%= page && page.layout === 'blank' ? 'selected' : '' %>>Blank Canvas (Empty Slate)</option>
                </select>
              </div>
              <div>
                <label class="form-label">Status</label>
                <select id="page-status" class="form-input">
                  <option value="DRAFT" <%= page && page.status === 'DRAFT' ? 'selected' : '' %>>Draft (Admin Only)</option>
                  <option value="STAGED" <%= page && page.status === 'STAGED' ? 'selected' : '' %>>Staged (Preview URL)</option>
                  <option value="PUBLISHED" <%= page && page.status === 'PUBLISHED' ? 'selected' : '' %>>Published (Instantly Live)</option>
                </select>
              </div>
            </div>

            <!-- SEO Meta Tags Panel -->
            <div style="border-top: 1px solid var(--border); padding-top: 1.5rem; margin-bottom: 1.5rem;">
              <h3 style="font-family: var(--font-head); font-size: 1.1rem; font-weight: 600; margin-bottom: 1rem; color: var(--text);">SEO &amp; Index Metadata</h3>
              <div style="display: grid; grid-template-columns: 1.2fr 1.8fr; gap: 1rem; margin-bottom: 1rem;">
                <div>
                  <label class="form-label">Robots Header</label>
                  <input type="text" id="meta-robots" value="<%= page ? page.metaRobots : 'index, follow' %>" class="form-input">
                </div>
                <div>
                  <label class="form-label">Canonical URL</label>
                  <input type="text" id="canonical-url" value="<%= page ? page.canonicalUrl : '' %>" placeholder="https://archie-garg.com/slug" class="form-input">
                </div>
              </div>
              <div>
                <label class="form-label">OG Sharing Image Card (URL)</label>
                <input type="text" id="og-image" value="<%= page ? page.ogImage : '' %>" placeholder="/uploads/card-share.png" class="form-input">
              </div>
            </div>

            <!-- Design Section (Theme Color & Gradients) -->
            <div style="border-top: 1px solid var(--border); padding-top: 1.5rem;">
              <h3 style="font-family: var(--font-head); font-size: 1.1rem; font-weight: 600; margin-bottom: 1rem; color: var(--text);">Design Branding</h3>
              
              <!-- Color Picker -->
              <div style="display: flex; align-items: center; gap: 1.5rem; margin-bottom: 1.5rem;">
                <div>
                  <label class="form-label" style="margin-bottom: 0.3rem;">Primary Theme Color</label>
                  <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <input type="color" id="theme-color" value="<%= page ? page.themeColor : '#6366f1' %>" onchange="syncColorInput(this.value)" style="border: none; background: none; width: 36px; height: 36px; cursor: pointer;">
                    <input type="text" id="theme-color-text" value="<%= page ? page.themeColor : '#6366f1' %>" class="form-input" style="width: 100px; padding: 0.4rem;" oninput="syncColorInput(this.value)">
                  </div>
                </div>
                <div style="flex-grow: 1;">
                  <span style="font-size: 0.82rem; color: var(--text-muted); line-height: 1.3; display: block;">This color is exposed as a CSS variable <code>--theme-color</code> and can be referenced in your page styling.</span>
                </div>
              </div>

              <!-- Gradient Builder -->
              <div>
                <label class="form-label">Background Gradient CSS</label>
                <input type="text" id="gradient-css" value="<%= page ? page.gradient : 'linear-gradient(135deg, #9d5cff 0%, #00d4ff 100%)' %>" placeholder="linear-gradient(...)" class="form-input" style="font-family: var(--font-mono); font-size: 0.85rem;" oninput="triggerPreviewUpdate()">
                
                <div style="margin-top: 1rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
                  <button onclick="applyGradient('linear-gradient(135deg, #9d5cff 0%, #00d4ff 100%)')" class="preset-grad" style="background: linear-gradient(135deg, #9d5cff 0%, #00d4ff 100%);"></button>
                  <button onclick="applyGradient('linear-gradient(135deg, #f43f5e 0%, #f59e0b 100%)')" class="preset-grad" style="background: linear-gradient(135deg, #f43f5e 0%, #f59e0b 100%);"></button>
                  <button onclick="applyGradient('linear-gradient(135deg, #10b981 0%, #059669 100%)')" class="preset-grad" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);"></button>
                  <button onclick="applyGradient('linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%)')" class="preset-grad" style="background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%);"></button>
                  <button onclick="applyGradient('linear-gradient(135deg, #0f172a 0%, #1e293b 100%)')" class="preset-grad" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border: 1px solid var(--border);"></button>
                </div>
              </div>
            </div>

            <!-- Commit History & Reverts -->
            <% if (page && commits && commits.length > 0) { %>
            <div style="border-top: 1px solid var(--border); padding-top: 1.5rem; margin-top: 1.5rem;">
              <h3 style="font-family: var(--font-head); font-size: 1.1rem; font-weight: 600; margin-bottom: 1rem; color: var(--text);">Branch Commit History</h3>
              <div style="max-height: 220px; overflow-y: auto; display: flex; flex-direction: column; gap: 0.6rem; border: 1px solid var(--border); border-radius: var(--r-sm); padding: 0.75rem; background: rgba(0,0,0,0.1);">
                <% commits.forEach(function(commit) { %>
                  <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.85rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.03);">
                    <div style="display: flex; flex-direction: column; max-width: 75%;">
                      <span style="font-weight: 600; color: var(--text); word-break: break-word;"><%= commit.message %></span>
                      <span style="font-family: var(--font-mono); font-size: 0.72rem; color: var(--cyan); margin-top: 0.1rem;">commit: <%= commit.hash.substring(0, 7) %></span>
                      <span style="font-size: 0.72rem; color: var(--text-muted); margin-top: 0.15rem;">
                        By <%= commit.author ? commit.author.name : 'Author' %> • <%= new Date(commit.createdAt).toLocaleString() %>
                      </span>
                    </div>
                    <button onclick="restoreCommit('<%= commit.hash %>')" class="btn btn-ghost" style="padding: 0.25rem 0.6rem; font-size: 0.72rem; border-color: var(--purple-dim);">
                      Checkout
                    </button>
                  </div>
                <% }); %>
              </div>
            </div>
            <% } %>

          </div>

          <!-- HTML PANEL -->
          <div id="panel-html" class="workspace-panel" style="height: 100%; display: none; flex-direction: column;">
            <!-- Editor Mode Selector -->
            <div style="display: flex; gap: 0.5rem; padding: 0.5rem 1rem; background: rgba(0,0,0,0.15); border-bottom: 1px solid var(--border);">
              <button onclick="toggleEditorMode('code')" id="editor-mode-code" class="editor-mode-btn active-mode-btn">Code Editor (Monaco)</button>
              <button onclick="toggleEditorMode('visual')" id="editor-mode-visual" class="editor-mode-btn">Visual Builder (Blocks)</button>
            </div>
            <div id="editor-html" style="width: 100%; flex: 1;"></div>
            <div id="builder-container" style="width: 100%; flex: 1; display: none; background: var(--bg-card); color: var(--text); overflow: hidden; position: relative;">
              <div style="display: flex; height: 100%; width: 100%;">
                
                <!-- Left Sidebar: Widget Registry -->
                <div id="builder-sidebar" style="width: 250px; background: rgba(0,0,0,0.25); border-right: 1px solid var(--border); display: flex; flex-direction: column; overflow-y: auto; padding: 1rem; flex-shrink: 0; user-select: none;">
                  <h3 style="font-family: var(--font-head); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-top: 0; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.4rem; font-weight: 700;">
                    <i data-lucide="plus-circle" style="width: 15px; height: 15px; color: var(--cyan);"></i> Blocks Palette
                  </h3>
                  <div id="widget-palette" style="display: flex; flex-direction: column; gap: 0.75rem;">
                    <!-- Widget Palette items will be generated by JS -->
                  </div>
                </div>

                <!-- Center Canvas: Active Layout Grid -->
                <div id="builder-canvas-wrapper" style="flex: 1; display: flex; flex-direction: column; background: rgba(0,0,0,0.08); overflow-y: auto; padding: 1.5rem; position: relative;">
                  <div id="builder-canvas" style="display: flex; flex-direction: column; gap: 1.25rem; min-height: 100%; padding-bottom: 8rem;">
                    <!-- Canvas elements will render here -->
                  </div>
                </div>

                <!-- Configurator Modal -->
                <div id="builder-drawer" onclick="closeConfigDrawerOnBackdrop(event)" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(8px); display: none; align-items: center; justify-content: center; z-index: 10000;">
                  <div id="config-modal-content" style="width: 90%; max-width: 650px; max-height: 85vh; background: #0c1424; border: 1px solid var(--border); border-radius: var(--r-lg); display: flex; flex-direction: column; overflow: hidden; box-shadow: 0 20px 50px rgba(0,0,0,0.6); position: relative; padding: 1.5rem;" onclick="event.stopPropagation()">
                    
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; border-bottom: 1px solid var(--border); padding-bottom: 0.75rem;">
                      <h3 style="font-family: var(--font-head); font-size: 1.1rem; color: var(--text); margin: 0; display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 700;">
                        <i data-lucide="sliders" style="width: 18px; height: 18px; color: var(--purple);"></i> Block Settings
                      </h3>
                      <button onclick="closeConfigDrawer()" style="background: none; border: none; color: var(--text-muted); cursor: pointer; display: flex; align-items: center; justify-content: center; padding: 4px; border-radius: 4px; transition: color 0.2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'"><i data-lucide="x" style="width: 20px; height: 20px;"></i></button>
                    </div>
                    
                    <div id="config-form-container" style="display: flex; flex-direction: column; gap: 1.5rem; overflow-y: auto; flex: 1; padding-right: 0.5rem; margin-bottom: 1rem;">
                      <!-- Dynamic Config Form elements will render here -->
                    </div>

                    <div style="display: flex; justify-content: flex-end; border-top: 1px solid var(--border); padding-top: 0.75rem; margin-top: 0.5rem;">
                      <button onclick="closeConfigDrawer()" class="btn btn-primary" style="padding: 0.5rem 1.5rem; font-size: 0.88rem;">
                        <span>Save &amp; Close</span>
                      </button>
                    </div>

                  </div>
                </div>

              </div>
            </div>
          </div>

          <!-- CSS PANEL -->
          <div id="panel-css" class="workspace-panel" style="height: 100%; display: none;">
            <div id="editor-css" style="width: 100%; height: 100%;"></div>
          </div>

          <!-- JS PANEL -->
          <div id="panel-js" class="workspace-panel" style="height: 100%; display: none;">
            <div id="editor-js" style="width: 100%; height: 100%;"></div>
          </div>

          <!-- DIFF VIEWER PANEL -->
          <div id="panel-diff" class="workspace-panel" style="height: 100%; display: none; flex-direction: column;">
            <!-- Diff Controls -->
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 1rem; background: rgba(0,0,0,0.15); border-bottom: 1px solid var(--border); flex-wrap: wrap; gap: 0.5rem;">
              <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
                <span style="font-family: var(--font-body); font-size: 0.8rem; color: var(--text-muted);">Compare:</span>
                <select id="diff-original-select" onchange="updateDiffComparison()" style="background: var(--bg); border: 1px solid var(--border); color: var(--text); border-radius: 4px; padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                  <% if (page && commits && commits.length > 0) { %>
                    <% commits.forEach(function(c, i) { %>
                      <option value="<%= c.hash %>" <%= i === 0 ? 'selected' : '' %> style="background: var(--bg-card); color: var(--text);">
                        [<%= c.hash.substring(0, 7) %>] <%= c.message.length > 25 ? c.message.substring(0, 22) + '...' : c.message %>
                      </option>
                    <% }); %>
                  <% } %>
                </select>
                <span style="font-family: var(--font-body); font-size: 0.8rem; color: var(--text-muted);">➔</span>
                <select id="diff-modified-select" onchange="updateDiffComparison()" style="background: var(--bg); border: 1px solid var(--border); color: var(--text); border-radius: 4px; padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                  <option value="unstaged" selected style="background: var(--bg-card); color: var(--text);">Unstaged Editor Changes</option>
                  <% if (page && commits && commits.length > 0) { %>
                    <% commits.forEach(function(c, i) { %>
                      <option value="<%= c.hash %>" style="background: var(--bg-card); color: var(--text);">
                        [<%= c.hash.substring(0, 7) %>] <%= c.message.length > 25 ? c.message.substring(0, 22) + '...' : c.message %>
                      </option>
                    <% }); %>
                  <% } %>
                </select>
              </div>
              <div style="display: flex; gap: 0.25rem;">
                <button onclick="setDiffType('html')" id="diff-btn-html" class="editor-mode-btn active-mode-btn">HTML</button>
                <button onclick="setDiffType('css')" id="diff-btn-css" class="editor-mode-btn">CSS</button>
                <button onclick="setDiffType('js')" id="diff-btn-js" class="editor-mode-btn">JS</button>
              </div>
            </div>
            <!-- Diff Editor Container -->
            <div id="editor-diff" style="width: 100%; flex: 1;"></div>
          </div>

        </div>
      </div>

      <!-- Right Panel: Side-by-Side Live Preview -->
      <div style="display: flex; flex-direction: column; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-lg); overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.3);">
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 1.5rem; background: rgba(8, 13, 26, 0.6); border-bottom: 1px solid var(--border);">
          <span style="font-family: var(--font-mono); font-size: 0.78rem; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.05em;">Interactive Live Preview</span>
          <button onclick="triggerPreviewUpdate()" style="color: var(--cyan); font-size: 0.8rem; font-family: var(--font-mono); border: 1px solid rgba(0, 212, 255, 0.2); border-radius: 4px; padding: 2px 8px; background: rgba(0, 212, 255, 0.05); cursor: pointer;" onmouseover="this.style.background='rgba(0, 212, 255, 0.15)'" onmouseout="this.style.background='rgba(0, 212, 255, 0.05)'">
            Reload Preview 🔄
          </button>
        </div>
        <div style="flex: 1; background: #fff; position: relative;">
          <iframe id="preview-frame" style="width: 100%; height: 100%; border: none; background: #fff;"></iframe>
        </div>
      </div>

    </div>

  </div>
</section>

<!-- Monaco Loader & Workspace Logic -->
<script>
  let htmlEditor, cssEditor, jsEditor, diffEditorInstance;
  let activeDiffType = 'html';
  const isEdit = <%= page ? 'true' : 'false' %>;

  const defaultHtml = `<div class="container section">
  <div class="section-header text-center">
    <div class="section-label">Welcome To My Custom Layout</div>
    <h2 class="section-title">Hello <span class="gradient-text">World</span></h2>
    <p class="section-subtitle">This page was created dynamically using our advanced Git VCS-integrated CMS.</p>
  </div>
  <div class="text-center" style="margin-top: 3rem;">
    <button onclick="triggerAnimation()" class="btn btn-primary">Click Me</button>
  </div>
</div>`;

  const defaultCss = `.gradient-text {
  background: var(--theme-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.section-header.text-center {
  text-align: center;
}
.text-center {
  text-align: center;
}`;

  const defaultJs = `function triggerAnimation() {
  alert("CMS Version Control works beautifully!");
}`;

  const htmlVal = isEdit ? `<%- page ? page.htmlContent.replace(/\\/g, '\\\\').replace(/\`/g, '\\\`').replace(/\$/g, '\\\$') : '' %>` : defaultHtml;
  const cssVal = isEdit ? `<%- page ? page.cssContent.replace(/\\/g, '\\\\').replace(/\`/g, '\\\`').replace(/\$/g, '\\\$') : '' %>` : defaultCss;
  const jsVal = isEdit ? `<%- page ? page.jsContent.replace(/\\/g, '\\\\').replace(/\`/g, '\\\`').replace(/\$/g, '\\\$') : '' %>` : defaultJs;

  // Initialize Monaco Editors
  require.config({ paths: { vs: 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.43.0/min/vs' } });
  require(['vs/editor/editor.main'], function () {
    
    // HTML Editor
    htmlEditor = monaco.editor.create(document.getElementById('editor-html'), {
      value: htmlVal,
      language: 'html',
      theme: 'vs-dark',
      automaticLayout: true,
      fontSize: 13,
      fontFamily: 'var(--font-mono)',
      minimap: { enabled: false }
    });

    // CSS Editor
    cssEditor = monaco.editor.create(document.getElementById('editor-css'), {
      value: cssVal,
      language: 'css',
      theme: 'vs-dark',
      automaticLayout: true,
      fontSize: 13,
      fontFamily: 'var(--font-mono)',
      minimap: { enabled: false }
    });

    // JS Editor
    jsEditor = monaco.editor.create(document.getElementById('editor-js'), {
      value: jsVal,
      language: 'javascript',
      theme: 'vs-dark',
      automaticLayout: true,
      fontSize: 13,
      fontFamily: 'var(--font-mono)',
      minimap: { enabled: false }
    });

    // Monaco Diff Editor
    const diffContainer = document.getElementById('editor-diff');
    if (diffContainer) {
      diffEditorInstance = monaco.editor.createDiffEditor(diffContainer, {
        theme: 'vs-dark',
        automaticLayout: true,
        fontSize: 13,
        fontFamily: 'var(--font-mono)',
        readOnly: true
      });
    }

    // Bind Ctrl+S shortcut to trigger commit modal
    const commitCommandId = monaco.KeyMod.CtrlCmd | monaco.KeyCode.KeyS;
    htmlEditor.addCommand(commitCommandId, function() {
      openCommitModal();
    });
    cssEditor.addCommand(commitCommandId, function() {
      openCommitModal();
    });
    jsEditor.addCommand(commitCommandId, function() {
      openCommitModal();
    });

    // Bind change listener to update preview on modifications
    htmlEditor.onDidChangeModelContent(debounce(triggerPreviewUpdate, 1500));
    cssEditor.onDidChangeModelContent(debounce(triggerPreviewUpdate, 1500));
    jsEditor.onDidChangeModelContent(debounce(triggerPreviewUpdate, 1500));

    triggerPreviewUpdate();
    
    // Initialize custom layout builder elements
    if (typeof initWidgetPalette === 'function') {
      initWidgetPalette();
    }
    if (typeof initCanvasSortable === 'function') {
      initCanvasSortable();
    }
  });

  function debounce(func, delay) {
    let timeout;
    return function() {
      const context = this;
      const args = arguments;
      clearTimeout(timeout);
      timeout = setTimeout(() => func.apply(context, args), delay);
    };
  }

  function switchWorkspaceTab(tab) {
    document.querySelectorAll('.workspace-tab-btn').forEach(btn => btn.classList.remove('active-w-tab'));
    document.querySelectorAll('.workspace-panel').forEach(panel => panel.style.display = 'none');

    document.getElementById(`workspace-tab-${tab}`).classList.add('active-w-tab');
    document.getElementById(`panel-${tab}`).style.display = tab === 'html' ? 'flex' : 'block';

    if (tab === 'html' && htmlEditor) {
      setTimeout(() => htmlEditor.layout(), 50);
    } else if (tab === 'css' && cssEditor) {
      setTimeout(() => cssEditor.layout(), 50);
    } else if (tab === 'js' && jsEditor) {
      setTimeout(() => jsEditor.layout(), 50);
    } else if (tab === 'diff') {
      document.getElementById(`panel-diff`).style.display = 'flex';
      updateDiffComparison();
      if (diffEditorInstance) {
        setTimeout(() => diffEditorInstance.layout(), 50);
      }
    }
  }

  function syncColorInput(val) {
    document.getElementById('theme-color').value = val;
    document.getElementById('theme-color-text').value = val;
    triggerPreviewUpdate();
  }

  function applyGradient(grad) {
    document.getElementById('gradient-css').value = grad;
    triggerPreviewUpdate();
  }

  function suggestSlug() {
    if (isEdit) return;
    const title = document.getElementById('page-title').value;
    const slugInput = document.getElementById('page-slug');
    const slug = title.toLowerCase()
      .trim()
      .replace(/[^a-z0-9-/]/g, '-')
      .replace(/-+/g, '-')
      .replace(/(^-|-$)/g, '');
    slugInput.value = slug;
  }

  function triggerPreviewUpdate() {
    if (!htmlEditor || !cssEditor || !jsEditor) return;

    const htmlContent = htmlEditor.getValue();
    const cssContent = cssEditor.getValue();
    const jsContent = jsEditor.getValue();
    const layout = document.getElementById('page-layout').value;
    const themeColor = document.getElementById('theme-color').value;
    const gradient = document.getElementById('gradient-css').value;

    const iframe = document.getElementById('preview-frame');
    const doc = iframe.contentDocument || iframe.contentWindow.document;

    let content = '';

    if (layout === 'blank') {
      content = `
        <!DOCTYPE html>
        <html lang="en">
        <head>
          <meta charset="UTF-8">
          <style>
            :root {
              --theme-color: ${themeColor};
              --theme-gradient: ${gradient};
            }
            body {
              margin: 0;
              padding: 0;
              min-height: 100vh;
              background: ${gradient};
              color: #e4ecf7;
              font-family: 'Inter', system-ui, sans-serif;
            }
            ${cssContent}
          </style>
        </head>
        <body>
          ${htmlContent}
          <script>${jsContent}<\/script>
        </body>
        </html>
      `;
    } else {
      content = `
        <!DOCTYPE html>
        <html lang="en">
        <head>
          <meta charset="UTF-8">
          <link rel="stylesheet" href="/css/style.css">
          <style>
            :root {
              --theme-color: ${themeColor};
              --theme-gradient: ${gradient};
            }
            body {
              background: #04060f;
              background-image: ${gradient};
              background-attachment: fixed;
            }
            ${cssContent}
          </style>
        </head>
        <body>
          <div class="navbar" style="position: relative; background: rgba(4, 6, 15, 0.85); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(130, 155, 200, 0.08);">
            <div class="container" style="display: flex; justify-content: space-between; align-items: center; height: 60px;">
              <span style="font-weight: 700; color: #fff; font-size: 1.1rem; font-family: 'Space Grotesk', sans-serif;"><span style="color:${themeColor}">⬤</span> <%= appName %></span>
              <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: ${themeColor}; border: 1px solid ${themeColor}; border-radius: 4px; padding: 2px 6px;">PREVIEW: <%= activeBranch %></span>
            </div>
          </div>
          <main class="main-content" style="padding-top: 40px; min-height: 450px;">
            ${htmlContent}
          </main>
          <footer style="text-align: center; padding: 2rem; border-top: 1px solid rgba(130, 155, 200, 0.05); color: #8a9bb8; font-size: 0.8rem;">
            &copy; ${new Date().getFullYear()} <%= appName %> • Version Controlled via CMS
          </footer>
          <script>${jsContent}<\/script>
        </body>
        </html>
      `;
    }

    doc.open();
    doc.write(content);
    doc.close();
  }

  // Branch & Commit Modals Controllers
  function openCommitModal() {
    document.getElementById('commit-modal').style.display = 'flex';
    document.getElementById('commit-message').focus();
  }
  function closeCommitModal() {
    document.getElementById('commit-modal').style.display = 'none';
  }

  function openBranchModal() {
    document.getElementById('branch-modal').style.display = 'flex';
    document.getElementById('new-branch-name').focus();
  }
  function closeBranchModal() {
    document.getElementById('branch-modal').style.display = 'none';
  }

  function openMergeRequestModal() {
    document.getElementById('mr-modal').style.display = 'flex';
    document.getElementById('mr-title').focus();
  }
  function closeMergeRequestModal() {
    document.getElementById('mr-modal').style.display = 'none';
  }

  function switchBranch(branchName) {
    const pageId = document.getElementById('page-id').value;
    window.location.href = `/admin/cms/pages/edit/${pageId}?branch=${branchName}`;
  }

  // VCS AJAX Submit Handlers
  async function submitCreateBranch() {
    const pageId = document.getElementById('page-id').value;
    const branchName = document.getElementById('new-branch-name').value;
    const sourceBranchId = document.getElementById('source-branch-select').value;

    if (!branchName) {
      showToastMsg('Branch name is required.', false);
      return;
    }

    try {
      const response = await fetch(`/admin/cms/pages/${pageId}/branches`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ branchName, sourceBranchId })
      });
      const result = await response.json();
      if (response.ok && result.success) {
        showToastMsg('Branch created successfully! Switching...', true);
        setTimeout(() => {
          window.location.href = `/admin/cms/pages/edit/${pageId}?branch=${result.branch.name}`;
        }, 1200);
      } else {
        showToastMsg(result.error || 'Failed to create branch', false);
      }
    } catch (err) {
      console.error(err);
      showToastMsg('A network error occurred', false);
    }
  }

  async function submitMergeRequest() {
    const pageId = document.getElementById('page-id').value;
    const title = document.getElementById('mr-title').value;
    const description = document.getElementById('mr-description').value;
    const sourceBranchId = document.getElementById('mr-source-select').value;
    const targetBranchId = document.getElementById('mr-target-select').value;

    if (!title || !targetBranchId) {
      showToastMsg('Title and Target branch are required.', false);
      return;
    }

    try {
      const response = await fetch(`/admin/cms/pages/${pageId}/merge-requests`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, description, sourceBranchId, targetBranchId })
      });
      const result = await response.json();
      if (response.ok && result.success) {
        showToastMsg('Merge Request submitted successfully!', true);
        closeMergeRequestModal();
        setTimeout(() => {
          window.location.href = '/admin/cms';
        }, 1200);
      } else {
        showToastMsg(result.error || 'Failed to file Merge Request', false);
      }
    } catch (err) {
      console.error(err);
      showToastMsg('A network error occurred', false);
    }
  }

  async function savePage() {
    const id = document.getElementById('page-id').value;
    const title = document.getElementById('page-title').value;
    const slug = document.getElementById('page-slug').value;
    const description = document.getElementById('page-description').value;
    const layout = document.getElementById('page-layout').value;
    const status = document.getElementById('page-status').value;
    const themeColor = document.getElementById('theme-color').value;
    const gradient = document.getElementById('gradient-css').value;
    const metaRobots = document.getElementById('meta-robots').value;
    const canonicalUrl = document.getElementById('canonical-url').value;
    const ogImage = document.getElementById('og-image').value;
    const commitMessage = document.getElementById('commit-message').value;

    if (!title || !slug) {
      showToastMsg('Title and Slug are required.', false);
      return;
    }

    const htmlContent = htmlEditor.getValue();
    const cssContent = cssEditor.getValue();
    const jsContent = jsEditor.getValue();

    const payload = {
      title,
      slug,
      description,
      layout,
      status,
      themeColor,
      gradient,
      htmlContent,
      cssContent,
      jsContent,
      metaRobots,
      canonicalUrl,
      ogImage,
      commitMessage: commitMessage || 'Update page content'
    };

    const url = id ? `/admin/cms/pages/edit/${id}?branch=<%= activeBranch %>` : '/admin/cms/pages';

    try {
      const response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const result = await response.json();

      if (response.ok && result.success) {
        showToastMsg('Changes committed and saved!', true);
        closeCommitModal();
        setTimeout(() => {
          window.location.href = result.redirectUrl;
        }, 1200);
      } else {
        showToastMsg(result.error || 'Failed to save changes', false);
      }
    } catch (err) {
      console.error(err);
      showToastMsg('A network error occurred', false);
    }
  }

  async function restoreCommit(commitHash) {
    const pageId = document.getElementById('page-id').value;
    if (!confirm('Are you sure you want to checkout this commit? Your unsaved draft changes in this branch will be replaced by a new revert commit.')) {
      return;
    }

    try {
      const response = await fetch(`/admin/cms/pages/edit/${pageId}/restore?branch=<%= activeBranch %>`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ revisionId: commitHash })
      });

      if (response.ok) {
        showToastMsg('Commit restored! Reloading...', true);
        setTimeout(() => {
          location.reload();
        }, 1200);
      } else {
        const result = await response.json();
        showToastMsg(result.error || 'Failed to restore commit', false);
      }
    } catch (err) {
      console.error(err);
      showToastMsg('A network error occurred', false);
    }
  }

  // Visual Block Builder State
  let canvasBlocks = [];
  let activeBlockId = null;
  let sortableInstance = null;
  let isVisualActive = false;

  // Widget Registry & Schemas
  const WIDGET_REGISTRY = {
    hero: {
      name: 'Hero Header',
      icon: 'heading',
      config: {
        title: { label: 'Title', type: 'text', default: 'Welcome to My Portfolio' },
        titleColor: { label: 'Title Color', type: 'color', default: '#ffffff' },
        subtitle: { label: 'Subtitle', type: 'text', default: 'AI Systems Architect & Full-Stack Platform Builder' },
        subtitleColor: { label: 'Subtitle Color', type: 'color', default: '#a1a1aa' },
        bgColor: { label: 'Background Color', type: 'color', default: '#111827' },
        alignment: { label: 'Alignment', type: 'select', options: ['left', 'center', 'right'], default: 'center' },
        primaryBtnText: { label: 'Primary Button Text', type: 'text', default: 'View Work' },
        primaryBtnUrl: { label: 'Primary Button Link', type: 'text', default: '#portfolio' },
        secondaryBtnText: { label: 'Secondary Button Text', type: 'text', default: 'Contact Me' },
        secondaryBtnUrl: { label: 'Secondary Button Link', type: 'text', default: '#contact' }
      },
      render: function(config) {
        const alignment = config.alignment || 'center';
        const alignItem = alignment === 'center' ? 'center' : (alignment === 'right' ? 'flex-end' : 'flex-start');
        const encoded = encodeURIComponent(JSON.stringify(config));
        return `<section data-widget="hero" data-config="${encoded}" class="widget-rendered-section" style="background-color: ${config.bgColor}; padding: 5rem 1.5rem; text-align: ${alignment}; display: flex; flex-direction: column; align-items: ${alignItem}; justify-content: center; min-height: 350px;">
  <div class="widget-rendered-container" style="display: flex; flex-direction: column; gap: 1rem; width: 100%;">
    <h1 style="color: ${config.titleColor}; font-family: 'Space Grotesk', sans-serif; font-size: clamp(2.2rem, 5vw, 3.5rem); font-weight: 700; margin: 0; line-height: 1.1;">${config.title}</h1>
    <p style="color: ${config.subtitleColor}; font-family: 'Inter', sans-serif; font-size: clamp(1rem, 2vw, 1.25rem); font-weight: 400; max-width: 700px; margin: ${alignment === 'center' ? '0 auto' : '0'}; line-height: 1.6;">${config.subtitle}</p>
    <div style="display: flex; gap: 1rem; justify-content: ${alignment === 'center' ? 'center' : (alignment === 'right' ? 'flex-end' : 'flex-start')}; margin-top: 1.5rem; flex-wrap: wrap;">
      ${config.primaryBtnText ? `<a href="${config.primaryBtnUrl}" style="display: inline-block; background: linear-gradient(135deg, #9d5cff 0%, #00d4ff 100%); color: #fff; padding: 0.75rem 1.75rem; border-radius: 8px; font-weight: 600; text-decoration: none; transition: transform 0.2s;">${config.primaryBtnText}</a>` : ''}
      ${config.secondaryBtnText ? `<a href="${config.secondaryBtnUrl}" style="display: inline-block; background: rgba(255,255,255,0.05); color: #fff; border: 1px solid rgba(255,255,255,0.15); padding: 0.75rem 1.75rem; border-radius: 8px; font-weight: 600; text-decoration: none; transition: background 0.2s;">${config.secondaryBtnText}</a>` : ''}
    </div>
  </div>
</section>`;
      },
      parse: function(el, currentConfig) {
        const config = { ...currentConfig };
        const h1 = el.querySelector('h1');
        if (h1) config.title = h1.textContent.trim();
        const p = el.querySelector('p');
        if (p) config.subtitle = p.textContent.trim();
        const links = el.querySelectorAll('a');
        if (links[0]) {
          config.primaryBtnText = links[0].textContent.trim();
          config.primaryBtnUrl = links[0].getAttribute('href');
        } else {
          config.primaryBtnText = '';
        }
        if (links[1]) {
          config.secondaryBtnText = links[1].textContent.trim();
          config.secondaryBtnUrl = links[1].getAttribute('href');
        } else {
          config.secondaryBtnText = '';
        }
        return config;
      }
    },
    text: {
      name: 'Rich Text Block',
      icon: 'file-text',
      config: {
        content: { label: 'HTML/Text Content', type: 'textarea', default: '<h2>Innovative Engineering</h2><p>Building scalable web architectures with node, postgres and modern css design tokens.</p>' },
        textColor: { label: 'Text Color', type: 'color', default: '#e4ecf7' },
        bgColor: { label: 'Background Color', type: 'color', default: '#0c1524' },
        padding: { label: 'Padding', type: 'text', default: '4rem 1.5rem' }
      },
      render: function(config) {
        const encoded = encodeURIComponent(JSON.stringify(config));
        return `<section data-widget="text" data-config="${encoded}" class="widget-rendered-section" style="background-color: ${config.bgColor}; padding: ${config.padding}; color: ${config.textColor};">
  <div class="widget-rendered-container" style="font-family: 'Inter', sans-serif; line-height: 1.7;">
    ${config.content}
  </div>
</section>`;
      },
      parse: function(el, currentConfig) {
        const config = { ...currentConfig };
        const container = el.querySelector('.widget-rendered-container');
        if (container) config.content = container.innerHTML.trim();
        return config;
      }
    },
    grid: {
      name: 'Featured Grid',
      icon: 'grid',
      config: {
        title: { label: 'Section Title', type: 'text', default: 'Featured Work' },
        titleColor: { label: 'Title Color', type: 'color', default: '#ffffff' },
        bgColor: { label: 'Background Color', type: 'color', default: '#090f1d' },
        columns: { label: 'Columns', type: 'select', options: ['2', '3', '4'], default: '3' },
        cards: { label: 'Cards', type: 'array', default: [
          { image: 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&w=600&q=80', title: 'Interactive VCS Dashboard', description: 'Full git-like commit tree with branching and visual diff comparison.', linkUrl: '#', badgeText: 'Core Tech' },
          { image: 'https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5?auto=format&fit=crop&w=600&q=80', title: 'Context-Aware AI Assistant', description: 'Prisma MCP tools enabling administrative operations inside chat.', linkUrl: '#', badgeText: 'AI Gateway' }
        ]}
      },
      render: function(config) {
        const encoded = encodeURIComponent(JSON.stringify(config));
        return `<section data-widget="grid" data-config="${encoded}" class="widget-rendered-section" style="background-color: ${config.bgColor}; padding: 4rem 1.5rem;">
  <div class="widget-rendered-container">
    ${config.title ? `<h2 style="color: ${config.titleColor}; font-family: 'Space Grotesk', sans-serif; font-size: 2rem; font-weight: 700; margin-top: 0; margin-bottom: 2rem; text-align: center;">${config.title}</h2>` : ''}
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; width: 100%;">
      ${config.cards.map(card => `
        <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; overflow: hidden; display: flex; flex-direction: column; transition: transform 0.2s;">
          ${card.image ? `<div style="height: 160px; overflow: hidden; background: #1a2333; position: relative;"><img src="${card.image}" style="width:100%; height:100%; object-fit:cover;" /></div>` : ''}
          <div style="padding: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; flex: 1;">
