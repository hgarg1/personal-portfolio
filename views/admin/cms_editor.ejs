    'custom-html': {
      name: 'Custom HTML',
      icon: 'code',
      config: {
        htmlCode: { label: 'Custom HTML Code', type: 'textarea', default: '<div style="padding: 2rem; border-radius: 8px; background: rgba(0,212,255,0.05); border: 1px solid rgba(0,212,255,0.15); text-align: center; color: var(--cyan); font-family: monospace;">[Custom HTML Block]</div>' }
