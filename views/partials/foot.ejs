    }
    .ai-btn-cancel:hover {
      background: rgba(255,255,255,0.05);
      color: var(--text);
    }
  </style>

  <script>
    let aiChatHistory = [
      { role: 'assistant', content: "Hello! I'm Harshit's AI Assistant. Ask me anything about his resume, technical skills, background, or credentials!" }
    ];

    function toggleAIChat() {
      const container = document.getElementById('ai-chat-container');
      const dot = document.querySelector('.ai-notification-dot');
      if (container.style.display === 'none') {
        container.style.display = 'flex';
        document.getElementById('ai-chat-input').focus();
        if (dot) dot.style.display = 'none'; // Clear notification dot
      } else {
        container.style.display = 'none';
      }
    }

    function clearAIChat() {
      if (!confirm('Clear message history?')) return;
      aiChatHistory = [
        { role: 'assistant', content: "Hello! I'm Harshit's AI Assistant. Ask me anything about his resume, technical skills, background, or credentials!" }
      ];
      const log = document.getElementById('ai-chat-messages');
      log.innerHTML = `
        <div class="ai-message ai-message-assistant">
          Hello! I'm Harshit's AI Assistant. Ask me anything about his resume, technical skills, background, or credentials!
        </div>
      `;
    }

    function sendSuggestedQuery(text) {
      const input = document.getElementById('ai-chat-input');
      input.value = text;
      document.getElementById('ai-chat-form').dispatchEvent(new Event('submit', { cancelable: true }));
    }

    function formatMarkdown(text) {
      if (!text) return '';
      // Escape HTML to prevent injection
      let html = text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
      
      // Formatting
      html = html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
      html = html.replace(/\*(.*?)\*/g, '<em>$1</em>');
      html = html.replace(/`(.*?)`/g, '<code style="background: rgba(0,0,0,0.3); padding: 2px 4px; border-radius: 4px; font-family: monospace; font-size: 0.85em; color: var(--cyan);">$1</code>');
      
      // Formatting lists
      html = html.replace(/^\s*[-*]\s+(.*?)$/gm, '<li>$1</li>');
      html = html.replace(/(<li>.*?<\/li>)/g, '<ul>$1</ul>');
      html = html.replace(/<\/ul>\s*<ul>/g, '');
      
      html = html.replace(/\n/g, '<br>');
      return html;
    }

    async function submitAIChat(e) {
      if (e) e.preventDefault();
      const input = document.getElementById('ai-chat-input');
      const text = input.value.trim();
      if (!text) return;

      input.value = '';
      input.disabled = true;

      // 1. Render User Message
      appendMessage('user', text);
      aiChatHistory.push({ role: 'user', content: text });

      // 2. Render Typing Indicator
      const messagesContainer = document.getElementById('ai-chat-messages');
      const loaderDiv = document.createElement('div');
      loaderDiv.className = 'ai-message ai-message-assistant';
      loaderDiv.id = 'ai-chat-loader';
      loaderDiv.innerHTML = `
        <div class="ai-loading-dots">
          <span class="ai-loading-dot"></span>
          <span class="ai-loading-dot"></span>
          <span class="ai-loading-dot"></span>
        </div>
      `;
      messagesContainer.appendChild(loaderDiv);
      messagesContainer.scrollTop = messagesContainer.scrollHeight;

      await triggerAIChatResponse();
      input.disabled = false;
      input.focus();
    }

    async function triggerAIChatResponse() {
      const messagesContainer = document.getElementById('ai-chat-messages');
      
      try {
        const pageTextContent = document.querySelector('main')?.innerText || document.body.innerText;
        
        const response = await fetch('/api/ai/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            messages: aiChatHistory,
            url: window.location.href,
            pageContent: pageTextContent.substring(0, 3000) // Keep context capped
          })
        });

        // Remove Typing Indicator
        const loader = document.getElementById('ai-chat-loader');
        if (loader) loader.remove();

        if (!response.ok) {
          let errMsg = '❌ Temporary connection error. Please try again.';
          if (response.status === 429) {
            errMsg = '⚠️ Too many requests. Please wait 60 seconds.';
            try {
              const errData = await response.json();
              if (errData && errData.error) {
                errMsg = `⚠️ ${errData.error}`;
              }
            } catch (e) {}
          } else {
            try {
              const errData = await response.json();
              if (errData && errData.error) {
                errMsg = `❌ ${errData.error}`;
              }
            } catch (e) {}
          }
          appendMessage('system', errMsg);
          return;
        }

        // Initialize empty assistant message element
        const assistantMessageDiv = document.createElement('div');
        assistantMessageDiv.className = 'ai-message ai-message-assistant';
        messagesContainer.appendChild(assistantMessageDiv);

        // Read stream
        const reader = response.body.getReader();
        const decoder = new TextDecoder();
        let textAccumulator = '';

        while (true) {
          const { value, done } = await reader.read();
          if (done) break;
          const chunk = decoder.decode(value, { stream: true });
          textAccumulator += chunk;

          // Strip tool calls from visual chat bubble
          const toolCallIndex = textAccumulator.lastIndexOf('[TOOL_CALLS]:');
          let cleanText = textAccumulator;
          if (toolCallIndex !== -1) {
            cleanText = textAccumulator.substring(0, toolCallIndex);
          }

          assistantMessageDiv.innerHTML = formatMarkdown(cleanText.trim());
          messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }

        // Process tool calls if any
        const toolCallIndex = textAccumulator.lastIndexOf('[TOOL_CALLS]:');
        if (toolCallIndex !== -1) {
          const cleanText = textAccumulator.substring(0, toolCallIndex).trim();
          aiChatHistory.push({ role: 'assistant', content: cleanText });
          
          const toolJson = textAccumulator.substring(toolCallIndex + '[TOOL_CALLS]:'.length);
          try {
            const toolData = JSON.parse(toolJson);
            if (toolData && toolData.toolResults) {
              toolData.toolResults.forEach(res => {
                if (res.result && res.result.status === 'pending_confirmation') {
                  renderConfirmationCard(res.result);
                }
              });
            }
          } catch (e) {
            console.error('Failed to parse tool JSON:', e);
          }
        } else {
          aiChatHistory.push({ role: 'assistant', content: textAccumulator.trim() });
        }

      } catch (err) {
        console.error(err);
        const loader = document.getElementById('ai-chat-loader');
        if (loader) loader.remove();
        appendMessage('system', '❌ Failed to communicate with Assistant.');
      }
    }

    function appendMessage(role, content) {
      const messagesContainer = document.getElementById('ai-chat-messages');
      const div = document.createElement('div');
      div.className = `ai-message ai-message-${role}`;
      div.innerHTML = role === 'system' ? content : formatMarkdown(content);
      messagesContainer.appendChild(div);
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    function renderConfirmationCard(toolResult) {
      const messagesContainer = document.getElementById('ai-chat-messages');
      const cardDiv = document.createElement('div');
      cardDiv.className = 'ai-confirm-card';
      cardDiv.id = `confirm-card-${Date.now()}`;
      cardDiv.innerHTML = `
        <div class="ai-confirm-title">⚠️ Admin Confirmation Required</div>
        <div style="font-size: 0.82rem; color: var(--text-muted); line-height: 1.4;">${toolResult.message}</div>
        <div class="ai-confirm-btns">
          <button onclick="executeConfirmedTool(this, '${toolResult.action}', '${toolResult.userId}', '${toolResult.email}', '${toolResult.newRole || ''}')" class="ai-btn-confirm">Confirm</button>
          <button onclick="cancelConfirmedTool(this)" class="ai-btn-cancel">Cancel</button>
        </div>
      `;
      messagesContainer.appendChild(cardDiv);
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    async function executeConfirmedTool(btn, action, userId, email, newRole) {
      btn.disabled = true;
      btn.textContent = 'Processing...';
      const cancelBtn = btn.nextElementSibling;
      if (cancelBtn) cancelBtn.style.display = 'none';

      try {
        const response = await fetch('/api/ai/execute-tool', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action, userId, email, newRole })
        });
        const result = await response.json();
        const card = btn.closest('.ai-confirm-card');

        if (response.ok && result.success) {
          card.innerHTML = `<div style="color: #10b981; font-size: 0.85rem; font-weight: 600;">✅ Action confirmed: ${result.message}</div>`;
          
          let toolResultMsg = `System confirmation: Action "${action}" succeeded for user ${email}. Result: ${result.message}`;
          if (result.newPassword) {
            toolResultMsg += ` New generated password is: ${result.newPassword}`;
          }

          aiChatHistory.push({ role: 'user', content: toolResultMsg });

          // Render Typing Indicator
          const messagesContainer = document.getElementById('ai-chat-messages');
          const loaderDiv = document.createElement('div');
          loaderDiv.className = 'ai-message ai-message-assistant';
          loaderDiv.id = 'ai-chat-loader';
          loaderDiv.innerHTML = `
            <div class="ai-loading-dots">
              <span class="ai-loading-dot"></span>
              <span class="ai-loading-dot"></span>
              <span class="ai-loading-dot"></span>
            </div>
          `;
          messagesContainer.appendChild(loaderDiv);
          messagesContainer.scrollTop = messagesContainer.scrollHeight;

          await triggerAIChatResponse();
        } else {
          card.innerHTML = `<div style="color: #ef4444; font-size: 0.85rem; font-weight: 600;">❌ Action failed: ${result.error || 'Server error'}</div>`;
        }
      } catch (err) {
        console.error(err);
        btn.textContent = 'Confirm';
        btn.disabled = false;
        if (cancelBtn) cancelBtn.style.display = 'inline-block';
      }
    }

    function cancelConfirmedTool(btn) {
      const card = btn.closest('.ai-confirm-card');
      card.innerHTML = `<div style="color: var(--text-muted); font-size: 0.85rem; font-style: italic;">🚫 Action cancelled by administrator.</div>`;
      
      aiChatHistory.push({ role: 'user', content: 'System confirmation: Action cancelled by administrator.' });
      
      // Render Typing Indicator
      const messagesContainer = document.getElementById('ai-chat-messages');
      const loaderDiv = document.createElement('div');
      loaderDiv.className = 'ai-message ai-message-assistant';
      loaderDiv.id = 'ai-chat-loader';
      loaderDiv.innerHTML = `
        <div class="ai-loading-dots">
          <span class="ai-loading-dot"></span>
          <span class="ai-loading-dot"></span>
          <span class="ai-loading-dot"></span>
        </div>
      `;
      messagesContainer.appendChild(loaderDiv);
      messagesContainer.scrollTop = messagesContainer.scrollHeight;

      triggerAIChatResponse();
    }
  </script>

  <script src="/js/main.js"></script>
</body>
