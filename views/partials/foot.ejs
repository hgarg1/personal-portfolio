      gap: 3px;
    }
    .ai-loading-dot {
      width: 6px;
      height: 6px;
      background: var(--text-muted);
      border-radius: 50%;
      animation: aiBounceDot 1.4s infinite ease-in-out both;
    }
    .ai-loading-dot:nth-child(1) { animation-delay: -0.32s; }
    .ai-loading-dot:nth-child(2) { animation-delay: -0.16s; }
    @keyframes aiBounceDot {
      0%, 80%, 100% { transform: scale(0); }
      40% { transform: scale(1.0); }
    }

    .ai-confirm-card {
      background: rgba(245, 158, 11, 0.04);
      border: 1px solid rgba(245, 158, 11, 0.2);
      border-radius: 8px;
      padding: 0.8rem 1rem;
      margin-top: 0.5rem;
      font-family: var(--font-body);
      align-self: stretch;
    }
    .ai-confirm-title {
      margin: 0 0 0.4rem;
      font-size: 0.85rem;
      font-weight: bold;
      color: #fbbf24;
    }
    .ai-confirm-btns {
      display: flex;
      gap: 0.5rem;
      margin-top: 0.75rem;
    }
    .ai-btn-confirm {
      background: #d97706;
      border: none;
      border-radius: 4px;
      color: white;
      font-size: 0.75rem;
      padding: 0.35rem 0.8rem;
      cursor: pointer;
      font-weight: 600;
      transition: background 0.2s;
    }
    .ai-btn-confirm:hover {
      background: #b45309;
    }
    .ai-btn-cancel {
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 4px;
      color: var(--text-muted);
      font-size: 0.75rem;
      padding: 0.35rem 0.8rem;
      cursor: pointer;
