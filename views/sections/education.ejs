<section id="education" class="section section-alt">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <span class="section-label">05 / Education</span>
      <h2 class="section-title">Academic <span class="gradient-text">Background</span></h2>
    </div>

    <div class="edu-card animate-on-scroll">
      <div class="edu-card-left">
        <div class="edu-school-badge">UMD</div>
        <div class="edu-school-info">
          <h3 class="edu-school"><%= education.school %></h3>
          <p class="edu-period"><%= education.period %></p>
        </div>
      </div>

      <div class="edu-card-right">
        <p class="edu-degree">
          <%= education.degree %>
          <span class="edu-track">— <%= education.track %></span>
        </p>
        <p class="edu-minors">
          <strong>Minors:</strong> <%= education.minors.join(' &amp; ') %>
        </p>

        <div class="edu-section">
          <h4 class="edu-sub-heading">Honors &amp; Awards</h4>
          <ul class="edu-list edu-list-awards">
            <% education.awards.forEach(function(award) { %>
            <li><span class="edu-check">&#10022;</span> <%= award %></li>
            <% }); %>
          </ul>
        </div>

        <div class="edu-two-col">
          <div class="edu-section">
            <h4 class="edu-sub-heading">Programs</h4>
            <ul class="edu-list">
              <% education.programs.forEach(function(p) { %>
              <li><%= p %></li>
              <% }); %>
              <% education.activities.forEach(function(a) { %>
              <li><%= a %></li>
              <% }); %>
            </ul>
          </div>
          <div class="edu-section">
            <h4 class="edu-sub-heading">Selected Coursework</h4>
            <ul class="edu-list">
              <% education.courses.forEach(function(c) { %>
              <li><%= c %></li>
              <% }); %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
