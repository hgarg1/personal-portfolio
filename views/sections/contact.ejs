<section id="contact" class="section section-alt">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <span class="section-label">07 / Contact</span>
      <h2 class="section-title">Let's <span class="gradient-text">Connect</span></h2>
      <p class="section-subtitle">Open to internships, full-time roles, collaborations, and interesting conversations.</p>
    </div>

    <div class="contact-layout animate-on-scroll">
      <div class="contact-links">
        <a href="mailto:<%= email %>" class="contact-link-card">
          <span class="contact-link-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          </span>
          <div>
            <p class="contact-link-label">Email</p>
            <p class="contact-link-value"><%= email %></p>
          </div>
        </a>
        <a href="<%= github %>" target="_blank" rel="noopener" class="contact-link-card">
          <span class="contact-link-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </span>
          <div>
            <p class="contact-link-label">GitHub</p>
            <p class="contact-link-value">github.com/hgarg1</p>
          </div>
        </a>
        <a href="<%= website %>" target="_blank" rel="noopener" class="contact-link-card">
          <span class="contact-link-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
          </span>
          <div>
            <p class="contact-link-label">Website</p>
            <p class="contact-link-value">harshit-garg.com</p>
          </div>
        </a>
        <a href="tel:<%= phone.replace(/\D/g,'') %>" class="contact-link-card">
          <span class="contact-link-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.41 2 2 0 0 1 3.59 1.26h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.82a16 16 0 0 0 6.29 6.29l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </span>
          <div>
            <p class="contact-link-label">Phone</p>
            <p class="contact-link-value"><%= phone %></p>
          </div>
        </a>
      </div>

      <form class="contact-form" id="contactForm" action="/contact" method="POST" novalidate>
        <div class="form-row">
          <div class="form-group">
            <label for="c_name" class="form-label">Name</label>
            <input type="text"  id="c_name"  name="name"    class="form-input" placeholder="Jane Doe"            required />
          </div>
          <div class="form-group">
            <label for="c_email" class="form-label">Email</label>
            <input type="email" id="c_email" name="email"   class="form-input" placeholder="jane@example.com"    required />
          </div>
        </div>
        <div class="form-group">
          <label for="c_msg" class="form-label">Message</label>
          <textarea id="c_msg" name="message" class="form-input form-textarea" placeholder="What's on your mind?" rows="5" required></textarea>
        </div>
        <div id="formStatus" class="form-status" aria-live="polite"></div>
        <button type="submit" class="btn btn-primary btn-full" id="submitBtn">Send Message &rarr;</button>
      </form>
    </div>
  </div>
</section>
