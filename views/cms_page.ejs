<% if (commit.layout === 'blank') { %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= commit.description || 'Custom page' %>" />
  <title><%= commit.title %></title>
  <style>
    :root {
      --theme-color: <%= commit.themeColor %>;
      --theme-gradient: <%= commit.gradient %>;
    }
    body {
      margin: 0;
      padding: 0;
      min-height: 100vh;
      background: <%= commit.gradient %>;
      color: #e4ecf7;
      font-family: 'Inter', system-ui, sans-serif;
    }
    <%= commit.cssContent %>
  </style>
</head>
<body>
  <%- commit.htmlContent %>
  
  <script>
    <%- commit.jsContent %>
  </script>
</body>
</html>
<% } else { %>
  <%- include('./partials/head') %>

  <style>
    :root {
      --theme-color: <%= commit.themeColor %>;
      --theme-gradient: <%= commit.gradient %>;
    }
    body {
      background-image: <%= commit.gradient %>;
      background-attachment: fixed;
    }
    <%= commit.cssContent %>
  </style>

  <%- commit.htmlContent %>

  <%- include('./partials/foot') %>

  <script>
    <%- commit.jsContent %>
  </script>
<% } %>
