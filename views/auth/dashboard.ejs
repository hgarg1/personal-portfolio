<%- include('../partials/head') %>

<section class="section">
  <div class="container">
    <div class="dashboard-wrapper">
      
      <!-- Dashboard Header -->
      <div class="dashboard-header animate-on-scroll">
        <div class="dashboard-title-info">
          <h1>System <span class="gradient-text">Pulse</span></h1>
          <p class="dashboard-welcome">Welcome back, <span><%= user.name || user.email %></span></p>
        </div>
        <form action="/auth/logout" method="POST" class="logout-form">
          <button type="submit">// logout</button>
        </form>
      </div>

      <!-- Admin Navigation Shortcuts -->
      <% if (user && (user.role === 'ADMIN' || user.role === 'EDITOR')) { %>
      <div class="submissions-panel admin-tools-panel animate-on-scroll">
        <div class="admin-tools-info">
          <span class="admin-tools-title">Administration Tools</span>
          <span class="admin-tools-desc">Manage site pages, media files, and update user access levels.</span>
        </div>
        <div class="admin-tools-actions">
          <a href="/admin/cms" class="btn btn-primary btn-admin-tool">
            CMS Control Panel 📊
          </a>
          <% if (user.role === 'ADMIN') { %>
            <a href="/admin/users" class="btn btn-ghost btn-admin-tool">
              User Management 👤
            </a>
          <% } %>
        </div>
      </div>
      <% } %>

      <!-- Contact Submissions Panel -->
      <div class="submissions-panel animate-on-scroll">
        <h2 class="sub-heading sub-heading-margin">Contact Form Submissions</h2>

        <% if (submissions && submissions.length > 0) { %>
          <div class="submissions-list">
            <% submissions.forEach(function(sub) { %>
              <div class="submission-card">
                <div class="submission-meta">
                  <div class="submission-sender">
                    <span class="submission-name"><%= sub.name %></span>
                    <a href="mailto:<%= sub.email %>" class="submission-email"><%= sub.email %></a>
                  </div>
                  <span class="submission-date">
                    <%= new Date(sub.createdAt).toLocaleString('en-US', { 
                      month: 'short', 
                      day: 'numeric', 
                      year: 'numeric',
                      hour: '2-digit',
                      minute: '2-digit'
                    }) %>
                  </span>
                </div>
                <p class="submission-message"><%= sub.message %></p>
                <% if (sub.email) { %>
                  <div class="submission-actions" style="margin-top: 1rem; display: flex; justify-content: flex-end;">
                    <button type="button" class="btn btn-ghost btn-reply-ai" style="padding: 0.35rem 0.75rem; font-size: 0.8rem; border-color: rgba(255,255,255,0.15);" 
                            data-name="<%= sub.name %>"
                            data-email="<%= sub.email %>"
                            data-message="<%= sub.message %>"
                            onclick="handleReplyClick(this)">
                      Reply with AI 🤖
                    </button>
                  </div>
                <% } %>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="no-submissions">
            <span class="no-submissions-icon">📥</span>
            <p class="no-submissions-text">No contact form submissions received yet.</p>
          </div>
        <% } %>
      </div>

      <!-- Passkeys & Biometrics Panel -->
      <div class="submissions-panel passkeys-panel animate-on-scroll">
        <div class="panel-header">
          <h2 class="sub-heading">Passkeys &amp; Biometrics</h2>
          <button type="button" class="btn btn-primary btn-add-passkey" id="registerPasskeyBtn">
            Add Passkey &nbsp;&#10022;
          </button>
        </div>

        <% if (passkeys && passkeys.length > 0) { %>
          <div class="submissions-list">
            <% passkeys.forEach(function(pk) { %>
              <div class="submission-card passkey-card">
                <div class="passkey-info">
                  <span class="submission-name passkey-name">
                    🔐 Passkey (Windows Hello / FaceID)
                  </span>
                  <span class="passkey-meta">
                    ID: <%= pk.credentialID.substring(0, 16) %>... | Created: <%= new Date(pk.createdAt).toLocaleDateString() %>
                  </span>
                </div>
                <button type="button" class="btn-delete-passkey" data-id="<%= pk.id %>">
                  // delete
                </button>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="no-submissions passkeys-empty">
            <span class="no-submissions-icon">🔑</span>
            <p class="no-submissions-text">No passkeys registered yet. Register a passkey to enable biometric login (Touch ID, Face ID, Windows Hello).</p>
          </div>
        <% } %>
      </div>

      <!-- AI Response Modal -->
      <div id="ai-response-modal" class="vcs-modal-backdrop" style="display: none;">
        <div class="vcs-modal-container" style="max-width: 650px; width: 95%;">
          <div class="vcs-modal-header">
            <h3 id="ai-modal-title">Draft Response with AI</h3>
            <button onclick="closeAIModal()">✕</button>
          </div>
          <div class="vcs-modal-body" style="padding: 1.5rem;">
            <div style="display: flex; flex-direction: column; gap: 1.25rem;">
              
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                  <span style="font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; display: block; margin-bottom: 0.25rem;">Recipient Name</span>
                  <span id="ai-recipient-name" style="font-size: 0.9rem; color: var(--text); font-weight: 500;"></span>
                </div>
                <div>
                  <span style="font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; display: block; margin-bottom: 0.25rem;">Recipient Email</span>
                  <span id="ai-recipient-email" style="font-family: var(--font-mono); font-size: 0.9rem; color: var(--text-muted); word-break: break-all;"></span>
                </div>
              </div>

              <div>
                <span style="font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; display: block; margin-bottom: 0.35rem;">Original Message</span>
                <div id="ai-original-message" style="background: rgba(0,0,0,0.15); border: 1px solid var(--border); border-radius: var(--r-sm); padding: 0.75rem 1rem; font-size: 0.82rem; max-height: 100px; overflow-y: auto; color: var(--text-muted); white-space: pre-wrap;"></div>
              </div>

              <div>
                <label class="form-label" style="font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; display: block; margin-bottom: 0.35rem;">Email Subject</label>
                <input type="text" id="ai-email-subject" class="form-input" style="font-size: 0.88rem;" value="Re: Contact Form Submission" />
              </div>

              <div>
                <label class="form-label" style="font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; display: block; margin-bottom: 0.35rem;">AI Generated Draft Response</label>
                <textarea id="ai-response-text" class="form-input" style="height: 250px; font-family: var(--font-body); font-size: 0.88rem; line-height: 1.5; resize: vertical; background: rgba(0,0,0,0.25);"></textarea>
              </div>

              <div id="ai-toast" style="display: none; padding: 0.5rem; border-radius: 4px; font-size: 0.82rem; font-family: var(--font-mono); text-align: center;"></div>

            </div>
          </div>
          <div class="vcs-modal-footer">
            <button onclick="regenerateAIDraft()" id="ai-regen-btn" class="btn btn-ghost" style="padding: 0.4rem 1.2rem; font-size: 0.85rem;" disabled>Regenerate Draft 🔄</button>
            <button onclick="sendAIResponse()" id="ai-send-btn" class="btn btn-primary" style="padding: 0.4rem 1.5rem; font-size: 0.85rem; box-shadow: none;" disabled>Send Response ✉️</button>
          </div>
        </div>
      </div>

    </div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const registerBtn = document.getElementById('registerPasskeyBtn');

    if (registerBtn) {
      registerBtn.addEventListener('click', async () => {
        try {
          // 1. Fetch registration options from server
          const optionsRes = await fetch('/auth/passkey/register-options');
          if (!optionsRes.ok) {
            const errData = await optionsRes.json();
            throw new Error(errData.error || 'Failed to fetch registration options.');
          }
          const options = await optionsRes.json();

          // Helper: Convert Base64Url to Uint8Array
          function base64urlToUint8Array(base64url) {
            const padding = '='.repeat((4 - (base64url.length % 4)) % 4);
            const base64 = (base64url + padding).replace(/\-/g, '+').replace(/_/g, '/');
            const rawData = window.atob(base64);
            const outputArray = new Uint8Array(rawData.length);
            for (let i = 0; i < rawData.length; ++i) {
              outputArray[i] = rawData.charCodeAt(i);
            }
            return outputArray;
          }

          // Transform options to support credential creation
          options.challenge = base64urlToUint8Array(options.challenge);
          options.user.id = base64urlToUint8Array(options.user.id);
          if (options.excludeCredentials) {
            options.excludeCredentials.forEach(cred => {
              cred.id = base64urlToUint8Array(cred.id);
            });
          }

          // 2. Trigger browser WebAuthn prompt
          const credential = await navigator.credentials.create({
            publicKey: options,
          });

          if (!credential) {
            throw new Error('Failed to create credentials.');
          }

          // Helper: Convert Uint8Array to Base64Url
          function uint8ArrayToBase64url(buffer) {
            const base64 = window.btoa(String.fromCharCode(...new Uint8Array(buffer)));
            return base64.replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
          }

          const credentialForServer = {
            id: credential.id,
            rawId: uint8ArrayToBase64url(credential.rawId),
            type: credential.type,
            response: {
              clientDataJSON: uint8ArrayToBase64url(credential.response.clientDataJSON),
              attestationObject: uint8ArrayToBase64url(credential.response.attestationObject),
              transports: typeof credential.response.getTransports === 'function' ? credential.response.getTransports() : ['internal'],
            },
          };

          // 3. Post verification response to server
          const registerRes = await fetch('/auth/passkey/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(credentialForServer),
          });

          const registerData = await registerRes.json();
          if (registerData.verified) {
            alert('🎉 Passkey successfully registered!');
            window.location.reload();
          } else {
            alert(registerData.error || 'Failed to verify passkey.');
          }
        } catch (err) {
          console.error(err);
          if (err.name !== 'NotAllowedError') {
            alert(err.message || 'An error occurred during passkey registration.');
          }
        }
      });
    }

    // Delete passkey logic
    document.querySelectorAll('.btn-delete-passkey').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Are you sure you want to delete this passkey?')) return;

        const id = btn.getAttribute('data-id');
        try {
          const res = await fetch('/auth/passkey/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id }),
          });

          const data = await res.json();
          if (data.success) {
            window.location.reload();
          } else {
            alert(data.error || 'Failed to delete passkey.');
          }
        } catch (err) {
          console.error(err);
          alert('An error occurred while deleting the passkey.');
        }
      });
    });

    // AI Respond Handlers
    let currentSubmission = { name: '', email: '', message: '' };

    window.handleReplyClick = function(btn) {
      const name = btn.getAttribute('data-name');
      const email = btn.getAttribute('data-email');
      const message = btn.getAttribute('data-message');
      openAIModal(name, email, message);
    };

    window.openAIModal = function(name, email, message) {
      currentSubmission = { name, email, message };
      draftResponse(name, email, message);
    };

    window.closeAIModal = function() {
      document.getElementById('ai-response-modal').style.display = 'none';
      const toast = document.getElementById('ai-toast');
      toast.style.display = 'none';
      toast.textContent = '';
      document.getElementById('ai-send-btn').textContent = 'Send Response ✉️';
    };

    window.regenerateAIDraft = function() {
      if (currentSubmission.name) {
        draftResponse(currentSubmission.name, currentSubmission.email, currentSubmission.message);
      }
    };

    async function draftResponse(name, email, message) {
      // Reset fields
      document.getElementById('ai-recipient-name').textContent = name;
      document.getElementById('ai-recipient-email').textContent = email;
      document.getElementById('ai-original-message').textContent = message;
      document.getElementById('ai-email-subject').value = `Re: Contact Form Submission - Harshit Garg`;
      document.getElementById('ai-response-text').value = 'Generating response draft... 🤖';
      
      // Disable buttons
      const regenBtn = document.getElementById('ai-regen-btn');
      const sendBtn = document.getElementById('ai-send-btn');
      regenBtn.disabled = true;
      sendBtn.disabled = true;

      // Show modal
      document.getElementById('ai-response-modal').style.display = 'flex';

      try {
        const response = await fetch('/api/ai/draft-response', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ name, email, message })
        });

        if (!response.ok) {
          throw new Error('Failed to generate draft.');
        }

        const reader = response.body.getReader();
        const decoder = new TextDecoder('utf-8');
        
        // Clear the placeholder
        document.getElementById('ai-response-text').value = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          const text = decoder.decode(value, { stream: true });
          document.getElementById('ai-response-text').value += text;
          
          // Auto-scroll textarea to bottom as it writes
          const textarea = document.getElementById('ai-response-text');
          textarea.scrollTop = textarea.scrollHeight;
        }
      } catch (err) {
        console.error(err);
        document.getElementById('ai-response-text').value = 'Error generating draft: ' + err.message;
      } finally {
        regenBtn.disabled = false;
        sendBtn.disabled = false;
      }
    }

    window.sendAIResponse = async function() {
      const toEmail = document.getElementById('ai-recipient-email').textContent;
      const toName = document.getElementById('ai-recipient-name').textContent;
      const subject = document.getElementById('ai-email-subject').value;
      const responseMessage = document.getElementById('ai-response-text').value;

      if (!toEmail || !subject || !responseMessage) {
        showAIStatus('Please make sure all fields are populated.', false);
        return;
      }

      const sendBtn = document.getElementById('ai-send-btn');
      const regenBtn = document.getElementById('ai-regen-btn');
      sendBtn.disabled = true;
      regenBtn.disabled = true;
      sendBtn.textContent = 'Sending... ⏳';

      try {
        const res = await fetch('/api/ai/send-response', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ toEmail, toName, subject, responseMessage })
        });

        const data = await res.json();
        if (res.ok && data.success) {
          showAIStatus('🎉 Response email sent successfully!', true);
          setTimeout(() => {
            closeAIModal();
          }, 2000);
        } else {
          throw new Error(data.error || 'Failed to send response email.');
        }
      } catch (err) {
        console.error(err);
        showAIStatus('❌ Error: ' + err.message, false);
        sendBtn.disabled = false;
        regenBtn.disabled = false;
        sendBtn.textContent = 'Send Response ✉️';
      }
    };

    function showAIStatus(msg, isSuccess) {
      const toast = document.getElementById('ai-toast');
      toast.style.display = 'block';
      toast.textContent = msg;
      if (isSuccess) {
        toast.style.background = 'rgba(16, 185, 129, 0.15)';
        toast.style.border = '1px solid rgba(16, 185, 129, 0.3)';
        toast.style.color = '#10b981';
      } else {
        toast.style.background = 'rgba(239, 68, 68, 0.15)';
        toast.style.border = '1px solid rgba(239, 68, 68, 0.3)';
        toast.style.color = '#ef4444';
      }
    }
  });
</script>
  </div>
</section>

<%- include('../partials/foot') %>
