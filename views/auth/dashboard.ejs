<%- include('../partials/head') %>

<section class="section">
  <div class="container">
    <div class="dashboard-wrapper">
      
      <!-- Dashboard Header -->
      <div class="dashboard-header animate-on-scroll">
        <div class="dashboard-title-info">
          <h1>System <span class="gradient-text">Pulse</span></h1>
          <p class="dashboard-welcome">Welcome back, <span><%= user.name || user.email %></span></p>
        </div>
        <form action="/auth/logout" method="POST" class="logout-form">
          <button type="submit">// logout</button>
        </form>
      </div>

      <!-- Contact Submissions Panel -->
      <div class="submissions-panel animate-on-scroll">
        <h2 class="sub-heading" style="margin-bottom: 1.5rem;">Contact Form Submissions</h2>

        <% if (submissions && submissions.length > 0) { %>
          <div class="submissions-list">
            <% submissions.forEach(function(sub) { %>
              <div class="submission-card">
                <div class="submission-meta">
                  <div class="submission-sender">
                    <span class="submission-name"><%= sub.name %></span>
                    <a href="mailto:<%= sub.email %>" class="submission-email"><%= sub.email %></a>
                  </div>
                  <span class="submission-date">
                    <%= new Date(sub.createdAt).toLocaleString('en-US', { 
                      month: 'short', 
                      day: 'numeric', 
                      year: 'numeric',
                      hour: '2-digit',
                      minute: '2-digit'
                    }) %>
                  </span>
                </div>
                <p class="submission-message"><%= sub.message %></p>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="no-submissions">
            <span class="no-submissions-icon">📥</span>
            <p class="no-submissions-text">No contact form submissions received yet.</p>
          </div>
        <% } %>
      </div>

    </div>
  </div>
</section>

<%- include('../partials/foot') %>
