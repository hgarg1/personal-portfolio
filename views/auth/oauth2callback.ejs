<%- include('../partials/head') %>

<section class="section auth-section">
  <div class="container">
    <div class="auth-box animate-on-scroll">
      <div class="auth-header" style="margin-bottom: 1.5rem;">
        <span class="auth-label" style="color: #10b981;">// authorization success</span>
        <h1 class="auth-title">Setup <span class="gradient-text">Complete</span></h1>
        <p class="auth-subtitle">Google OAuth2 credentials have been successfully exchanged and configured.</p>
      </div>

      <div class="auth-success-info" style="display: flex; flex-direction: column; gap: 1rem; background: rgba(16, 185, 129, 0.05); border: 1px solid rgba(16, 185, 129, 0.2); border-radius: var(--r-md); padding: 1.25rem; margin-bottom: 1.5rem; font-size: 0.88rem; line-height: 1.6;">
        <div style="display: flex; justify-content: space-between; gap: 0.5rem; flex-wrap: wrap;">
          <span style="color: var(--text-muted);">Gmail Account:</span>
          <span style="font-weight: 600; color: var(--text);"><%= email %></span>
        </div>
        <div style="display: flex; flex-direction: column; gap: 0.25rem;">
          <span style="color: var(--text-muted);">OAuth2 Refresh Token:</span>
          <code style="background: rgba(0,0,0,0.3); border: 1px solid var(--border); padding: 0.5rem; border-radius: var(--r-sm); font-size: 0.75rem; word-break: break-all; color: #a78bfa; font-family: var(--font-mono);"><%= refreshToken %></code>
        </div>
      </div>

      <div style="font-size: 0.82rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 2rem; border-left: 2px solid var(--purple); padding-left: 0.75rem;">
        <strong>Configuration Update:</strong> The environment variables <code>GMAIL_USER</code>, <code>GMAIL_CLIENT_ID</code>, <code>GMAIL_CLIENT_SECRET</code>, and <code>GMAIL_REFRESH_TOKEN</code> have been successfully written to your <code>.env</code> file.
      </div>

      <a href="/auth" class="btn btn-primary btn-full" style="text-decoration: none; text-align: center; display: block; line-height: 1.4;">
        Proceed to Portal &nbsp;&#10022;
      </a>
    </div>
  </div>
</section>

<%- include('../partials/foot') %>
