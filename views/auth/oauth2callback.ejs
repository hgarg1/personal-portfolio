<%- include('../partials/head') %>

<section class="section auth-section">
  <div class="container">
    <div class="auth-box animate-on-scroll">
      <div class="auth-header auth-header-sm">
        <span class="auth-label auth-label-success">// authorization success</span>
        <h1 class="auth-title">Setup <span class="gradient-text">Complete</span></h1>
        <p class="auth-subtitle">Google OAuth2 credentials have been successfully exchanged and configured.</p>
      </div>

      <div class="auth-success-info">
        <div class="auth-success-row">
          <span class="auth-success-label">Gmail Account:</span>
          <span class="auth-success-val"><%= email %></span>
        </div>
        <div class="auth-success-col">
          <span class="auth-success-label">OAuth2 Refresh Token:</span>
          <code class="auth-success-code"><%= refreshToken %></code>
        </div>
      </div>

      <div class="auth-config-note">
        <strong>Configuration Update:</strong> The environment variables <code>GMAIL_USER</code>, <code>GMAIL_CLIENT_ID</code>, <code>GMAIL_CLIENT_SECRET</code>, and <code>GMAIL_REFRESH_TOKEN</code> have been successfully written to your <code>.env</code> file.
      </div>

      <a href="/auth" class="btn btn-primary btn-full btn-auth-link">
        Proceed to Portal &nbsp;&#10022;
      </a>
    </div>
  </div>
</section>

<%- include('../partials/foot') %>
